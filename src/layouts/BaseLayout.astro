---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import "../styles/animations.css";
import Navigation from "../components/Navigation.astro";
import CosmicBackground from "../components/CosmicBackground.astro";
import Footer from "../components/Footer.astro";
import AstralChat from "../components/AstralChat.astro";
import { getLocaleFromPathname, localizePath } from "../i18n/utils";

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = "Portfolio d’Alexandre Noblet, développeur et intégrateur IoT.",
  ogTitle = title,
  ogDescription = description,
  ogImage = "/images/website/portfolio.png",
  canonical,
} = Astro.props;

const locale = getLocaleFromPathname(Astro.url.pathname);
const enPath = localizePath(Astro.url.pathname, "en");
const frPath = localizePath(Astro.url.pathname, "fr");
const origin = Astro.site?.toString() || Astro.url.origin;
const canonicalUrl = canonical ? new URL(canonical, origin).toString() : Astro.url.toString();
const ogImageUrl = new URL(ogImage, origin).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/images/website/portfolio.png" />
    <meta name="view-transition" content="same-origin" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="alternate" hreflang="fr" href={frPath} />
    <link rel="alternate" hreflang="en" href={enPath} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://fonts.cdnfonts.com" />
    <link rel="stylesheet" href="https://fonts.cdnfonts.com/css/blanka" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,700;1,400;1,700&family=Manrope:wght@400;500;700&family=Poppins:wght@400;500;600;700&display=swap" />
    <ClientRouter />
    <script is:inline>
      if (typeof navigator !== 'undefined' && /firefox/i.test(navigator.userAgent)) {
        document.startViewTransition = undefined;
      }
    </script>
    <script is:inline>
      (() => {
        if (typeof window === "undefined") return;

        const defaultLocale = "fr";
        const supportedLocales = ["fr", "en"];
        const localeCookie = `portfolio_locale=`;

        const getCookieLocale = () => {
          const entry = document.cookie
            .split(";")
            .map((value) => value.trim())
            .find((value) => value.startsWith(localeCookie));
          return entry?.slice(localeCookie.length);
        };

        const normalize = (path) => {
          const cleaned = path.replace(/\/$/, "") || "/";
          const segments = cleaned.split("/").filter(Boolean);
          if (segments.length > 0 && supportedLocales.includes(segments[0])) {
            return `/${segments.slice(1).join("/")}` || "/";
          }
          return cleaned;
        };

        const currentPath = window.location.pathname;
        const browserPreference = navigator.language.toLowerCase().startsWith("en") ? "en" : defaultLocale;
        const preferredLocale = getCookieLocale() || localStorage.getItem("preferredLocale") || browserPreference;

        if (!supportedLocales.includes(preferredLocale)) return;

        const hasLocalePrefix = /^\/(fr|en)(\/|$)/.test(currentPath);
        const basePath = normalize(currentPath);
        const targetPath = preferredLocale === defaultLocale ? basePath : `/${preferredLocale}${basePath === "/" ? "" : basePath}`;

        const isTopLevelPath = basePath === "/" || /^\/[^/]+$/.test(basePath);

        if (!hasLocalePrefix && isTopLevelPath && targetPath !== currentPath) {
          window.location.replace(targetPath);
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <CosmicBackground />
    <Navigation transition:name="site-navigation" />
    <slot name="fixed-layer" />
    <AstralChat locale={locale} />
    <main
      class="page-shell relative z-10 pt-20 pb-8 md:pt-32 md:pb-12"
      transition:name="page-content"
    >
      <slot />
    </main>
    <Footer locale={locale} />
    <script>
      // Preserve CSS <link> tags across ClientRouter navigations.
      // When Astro's ClientRouter swaps pages (e.g. locale switch /fr ↔ /en),
      // it compares <link rel="stylesheet"> hrefs between old and new pages and
      // removes any that are absent from the new page — causing a CSS flash or
      // full CSS loss. This copies every stylesheet from the current page into
      // the incoming document before the swap so ClientRouter always keeps them.
      document.addEventListener('astro:before-swap', (e: any) => {
        const newHead = e.newDocument.head;
        document.querySelectorAll<HTMLLinkElement>('link[rel="stylesheet"]').forEach((link) => {
          const href = link.getAttribute('href');
          if (!href) return;
          if (!newHead.querySelector(`link[rel="stylesheet"][href="${href}"]`)) {
            const clone = document.createElement('link');
            clone.rel = 'stylesheet';
            clone.setAttribute('href', href);
            newHead.prepend(clone);
          }
        });
      });
    </script>

    <script>
      // Smoothly reveal images only once the browser has fully loaded them.
      function initFadeImages() {
        document.querySelectorAll<HTMLImageElement>('[data-fade-image]').forEach((img) => {
          if (img.dataset.fadeReady === '1') return;

          const reveal = () => {
            img.classList.add('is-loaded');
            const skeleton = img.previousElementSibling as HTMLElement | null;
            if (skeleton?.classList.contains('hero-skeleton') || skeleton?.classList.contains('hero-img-skeleton')) {
              skeleton.style.display = 'none';
            }
            img.dataset.fadeReady = '1';
          };

          if (img.complete && img.naturalWidth > 0) {
            reveal();
          } else {
            img.addEventListener('load', reveal, { once: true });
          }
        });
      }

      if (!(window as any).__fadeImagesBound) {
        document.addEventListener('astro:page-load', initFadeImages);
        (window as any).__fadeImagesBound = true;
      }

      initFadeImages();
    </script>

    <script>
      function updateAstralChatVisibility() {
        const isOnChat =
          ["/chat", "/en/chat"].includes(window.location.pathname.replace(/\/$/, ""));
        const widget = document.querySelector(
          "[data-astral-chat-root][data-mode='floating']",
        ) as HTMLElement | null;
        if (widget) {
          widget.style.display = isOnChat ? "none" : "";
        }
      }

      document.addEventListener("astro:after-swap", () => {
        updateAstralChatVisibility();

        // Sync locale-dependent text in persisted AstralChat widget.
        // The widget is kept alive by transition:persist but its HTML is baked at
        // build time — update the visible strings whenever the lang attribute changes.
        const en = document.documentElement.lang === "en";
        const widget = document.querySelector<HTMLElement>("[data-astral-chat-root]");
        if (!widget) return;

        const kicker = widget.querySelector(".astral-chat__kicker");
        if (kicker) kicker.textContent = en ? "Stellar companion" : "Compagnon stellaire";

        const heading = widget.querySelector<HTMLElement>(".astral-chat__header h2");
        if (heading) heading.textContent = en ? "Astral · AI assistant" : "Astral · Assistant IA";

        const fs = widget.querySelector<HTMLAnchorElement>(".astral-chat__fullscreen");
        if (fs) {
          fs.href = en ? "/en/chat" : "/chat";
          fs.setAttribute("aria-label", en ? "Open fullscreen" : "Ouvrir en plein écran");
          fs.title = en ? "Open fullscreen" : "Ouvrir en plein écran";
        }

        const clearBtn = widget.querySelector<HTMLButtonElement>(".astral-chat__clear");
        if (clearBtn) {
          clearBtn.setAttribute("aria-label", en ? "New conversation" : "Nouvelle conversation");
          clearBtn.title = en ? "New conversation" : "Nouvelle conversation";
        }

        const closeBtn = widget.querySelector<HTMLButtonElement>(".astral-chat__close");
        if (closeBtn) closeBtn.setAttribute("aria-label", en ? "Close chat" : "Fermer le chat");

        const textarea = widget.querySelector<HTMLTextAreaElement>("textarea");
        if (textarea) textarea.placeholder = en ? "Write your message…" : "Écrivez votre message…";

        const triggerLabel = widget.querySelector<HTMLElement>(".astral-chat__trigger .sr-only");
        if (triggerLabel) triggerLabel.textContent = en ? "Open Astral chat" : "Ouvrir le chat Astral";
      });

      document.addEventListener("astro:page-load", () => {
        updateAstralChatVisibility();
        const isRecruiterPage = ["/recruiter", "/en/recruiter"].includes(window.location.pathname);
        const nextMode = isRecruiterPage ? "on" : "off";
        document.body.setAttribute("data-recruiter-mode", nextMode);
        document.dispatchEvent(
          new CustomEvent("portfolio:recruiter-mode", {
            detail: { mode: nextMode },
          }),
        );
      });
    </script>
  </body>
</html>
