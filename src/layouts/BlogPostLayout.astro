---
import BaseLayout from "./BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import { getLocaleFromPathname } from "../i18n/utils";

interface Frontmatter {
  title: string;
  description?: string;
  date?: string;
  heroImage?: string;
  blogTitle?: string;
  parentLink?: string;
}

const { frontmatter } = Astro.props as { frontmatter: Frontmatter };
const {
  title,
  description = "",
  date,
  heroImage,
  blogTitle,
  parentLink = "/blogs",
} = frontmatter;

import { Image } from "astro:assets";
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif,webp,avif}",
  { eager: true },
);
const resolveImage = (path?: string) =>
  path && images[`/src/assets${path}`]
    ? images[`/src/assets${path}`].default
    : null;

const heroImageSrc = resolveImage(heroImage);
const locale = getLocaleFromPathname(Astro.url.pathname);
const isEn = locale === "en";
---

<BaseLayout title={`Alexandre Noblet | ${title}`} description={description}>
  <article class="cosmic-container pt-8">
    <Button href={parentLink} variant="outline" icon="lucide:arrow-left">
      {isEn ? "Back" : "Retour"}
    </Button>

    <header class="mt-6">
      {
        blogTitle && (
          <p class="text-sm uppercase tracking-[0.25em] text-cosmic-pink">
            {blogTitle}
          </p>
        )
      }
      <h1 class="section-title mt-3">{title}</h1>
      {date && <p class="muted mt-3">{isEn ? "Published on" : "Publié le"} {date}</p>}
    </header>

    {
      heroImageSrc && (
        <Card class="relative mt-6 overflow-hidden">
          <div class="hero-img-skeleton absolute inset-0 animate-pulse bg-white/5" />
          <Image
            src={heroImageSrc}
            alt={title}
            class="hero-img relative h-auto w-full object-cover opacity-0 transition-opacity duration-700"
            onload="this.classList.add('loaded'); this.previousElementSibling.style.display='none';"
          />
        </Card>
      )
    }

    <style>
      .hero-img.loaded {
        opacity: 1;
      }
    </style>

    <Card class="mt-6 p-6 md:p-8">
      <div class="article-content">
        <slot />
      </div>
    </Card>
  </article>
</BaseLayout>
