---
import type { Locale } from "../i18n/config";

const { locale = 'fr' } = Astro.props as { locale?: Locale };
const isEn = locale === 'en';
---

<section class="cosmic-container mt-12 text-center">
  <div class="mx-auto grid h-72 w-72 place-items-center rounded-full border-2 border-cosmic-gold/80 bg-linear-to-br from-violet-500/20 to-cyan-400/20 pulse-glow">
    <div class="grid h-48 w-48 place-items-center rounded-full border border-cosmic-gold/50 bg-black/40">
      <p class="font-display text-5xl text-cosmic-gold">OBS</p>
    </div>
  </div>
  <p class="muted mx-auto mt-5 max-w-2xl">
    {isEn
      ? 'From Live Tag to PlanetTogether, these company projects strengthened my Flutter, Python, CI/CD, GitLab, and IoT integration skills.'
      : 'De Live Tag à PlanetTogether, ces expériences en entreprise m’ont permis de consolider mes compétences en Flutter, Python, CI/CD, GitLab et intégration IoT.'}
  </p>
</section>
