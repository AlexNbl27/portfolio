---
const links = [
  { href: '/', label: 'Accueil' },
  { href: '/projects', label: 'Projets' },
  { href: '/skills', label: 'Compétences' },
  { href: '/soft-skills', label: 'Soft skills' },
  { href: '/experience', label: 'Parcours' },
  { href: '/blogs', label: 'Blogs' }
];

const current = Astro.url.pathname;
---

<header class="fixed inset-x-0 top-0 z-50 pt-2">
  <div class="cosmic-container">
    <nav class="glass-card flex flex-wrap items-center justify-between gap-3 px-4 py-3 shadow-[0_18px_40px_rgba(4,9,22,0.28)] md:px-6" aria-label="Navigation principale">
    <a href="/" class="focus-ring font-display text-2xl font-bold italic tracking-wide text-cosmic-gold">Alexandre Noblet</a>

    <button class="focus-ring rounded-md px-2 py-1 md:hidden" id="menu-toggle" aria-expanded="false" aria-controls="menu" aria-label="Ouvrir le menu">☰</button>

    <ul id="menu" class="hidden w-full flex-col gap-3 border-t border-cosmic-gold/20 pt-3 text-xs uppercase tracking-[0.15em] md:flex md:w-auto md:flex-row md:items-center md:border-none md:pt-0">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'focus-ring border-b pb-1 transition hover:text-cosmic-gold',
              current === link.href ? 'border-cosmic-gold text-cosmic-gold' : 'border-transparent'
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="mailto:alexandrenobletpro@gmail.com" class="focus-ring rounded-full border border-cosmic-gold/35 bg-cosmic-gold px-4 py-2 font-bold text-black transition hover:shadow-glow">Contact</a>
      </li>
    </ul>
    </nav>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('menu');

  menuToggle?.addEventListener('click', () => {
    if (!menu) return;
    const isHidden = menu.classList.toggle('hidden');
    menuToggle.setAttribute('aria-expanded', String(!isHidden));
  });
</script>
