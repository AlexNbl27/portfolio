---
import Card from "./ui/Card.astro";
import Button from "./ui/Button.astro";
import { getLocaleFromPathname, localizePath } from "../i18n/utils";

const locale = getLocaleFromPathname(Astro.url.pathname);

const links = [
  { href: "/projects", label: locale === "en" ? "Projects" : "Projets" },
  { href: "/expertise", label: locale === "en" ? "Expertise" : "Expertise" },
  { href: "/services", label: locale === "en" ? "Services" : "Services" },
  { href: "/experience", label: locale === "en" ? "Journey" : "Parcours" },
  { href: "/blogs", label: "Blog" },
  {
    href: "/chat",
    label: locale === "en" ? "AI Chat" : "Chat IA",
    mobileOnly: true,
  },
].map((link) => ({ ...link, href: localizePath(link.href, locale) }));

const norm = (p: string) => (p === "/" ? p : p.replace(/\/$/, ""));
const current = norm(Astro.url.pathname);
const homeHref = localizePath("/", locale);
const contactLabel = locale === "en" ? "Contact" : "Contact";

const expertiseSubRoutes = [
  "/skills",
  "/soft-skills",
  "/en/skills",
  "/en/soft-skills",
];
const isActive = (href: string) =>
  norm(current) === norm(href) ||
  (href.includes("/expertise") &&
    expertiseSubRoutes.some((r) => norm(current) === r));
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 pt-0 transition-transform duration-300 ease-out md:pt-4"
>
  <div class="w-full mx-auto md:max-w-6xl">
    <Card
      as="nav"
      id="nav-card"
      class="flex flex-col items-center justify-between px-4 py-2.5 shadow-[0_18px_40px_rgba(4,9,22,0.28)] !rounded-none border-x-0 border-t-0 transition-all duration-500 ease-in-out data-[mobile-open=true]:h-[100dvh] data-[mobile-open=true]:overflow-y-auto md:px-5 md:py-3.5 md:!rounded-card md:border-x md:border-t md:flex-row md:data-[mobile-open=true]:h-auto md:data-[mobile-open=true]:overflow-visible"
      aria-label={locale === "en" ? "Main navigation" : "Navigation principale"}
    >
      <div class="flex min-h-11 w-full items-center justify-between md:w-auto shrink-0">
        <a
          href={homeHref}
          class="focus-ring inline-flex min-h-11 items-center font-blanka text-base leading-none tracking-[0.2em] text-white transition-colors duration-300 hover:text-cosmic-gold md:text-2xl md:tracking-widest md:-translate-y-[5px]"
          >Alexandre Noblet</a
        >
        <button
          class="focus-ring tap-feedback group relative h-11 w-11 md:hidden"
          id="menu-toggle"
          aria-expanded="false"
          aria-controls="menu"
          aria-label="Menu"
        >
          <div
            class="absolute left-1/2 top-1/2 w-6 -translate-x-1/2 -translate-y-1/2 transform"
          >
            <span
              id="burger-top"
              class="absolute block h-0.5 w-6 transition-all duration-300 ease-in-out bg-white -translate-y-2"
            ></span>
            <span
              id="burger-mid"
              class="absolute block h-0.5 w-6 transition-all duration-300 ease-in-out bg-white"
            ></span>
            <span
              id="burger-bot"
              class="absolute block h-0.5 w-6 transition-all duration-300 ease-in-out bg-white translate-y-2"
            ></span>
          </div>
        </button>
      </div>

      <ul
        id="menu"
        class="hidden w-full flex-1 flex-col items-center justify-center gap-4 pt-4 pb-10 text-base uppercase tracking-[0.18em] md:!flex md:w-auto md:flex-none md:flex-row md:ml-auto md:gap-5 md:p-0 md:text-xs md:tracking-[0.14em] data-[mobile-open=true]:flex"
      >
        {
          links.map((link) => (
            <li
              class:list={[
                "nav-item opacity-0 translate-y-8 flex items-center md:opacity-100 md:translate-y-0",
                link.mobileOnly ? "md:hidden" : "",
              ]}
            >
              <a
                href={link.href}
                aria-current={isActive(link.href) ? "page" : undefined}
                class:list={[
                  "focus-ring tap-feedback inline-flex min-h-11 items-center border-b px-2 py-1 transition hover:text-cosmic-gold md:min-h-0 md:py-0.5",
                  isActive(link.href)
                    ? "border-cosmic-gold text-cosmic-gold"
                    : "border-transparent",
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li
          class="nav-item opacity-0 translate-y-8 md:opacity-100 md:translate-y-0 mt-2 md:mt-0"
        >
          <Button href={localizePath("/contact", locale)} variant="primary">
            {contactLabel}
          </Button>
        </li>
      </ul>
    </Card>
  </div>
</header>

<script>
  function updateActiveLinks() {
    const expertiseSubRoutes = [
      "/skills",
      "/soft-skills",
      "/en/skills",
      "/en/soft-skills",
    ];
    const norm = (p: string) => (p === "/" ? p : p.replace(/\/$/, ""));
    const current = norm(window.location.pathname);

    document
      .querySelectorAll<HTMLAnchorElement>("#menu a[href]")
      .forEach((link) => {
        const href = norm(link.getAttribute("href") || "");
        const active =
          current === href ||
          (href.includes("/expertise") &&
            expertiseSubRoutes.some((r) => norm(current) === r)) ||
          (href.endsWith("/blogs") && current.includes("/blogs"));

        link.classList.toggle("border-cosmic-gold", active);
        link.classList.toggle("text-cosmic-gold", active);
        link.classList.toggle("border-transparent", !active);
        if (active) {
          link.setAttribute("aria-current", "page");
        } else {
          link.removeAttribute("aria-current");
        }
      });
  }

  document.addEventListener("astro:page-load", () => {
    updateActiveLinks();

    const menuToggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("menu");
    const navCard = document.getElementById("nav-card");
    const bTop = document.getElementById("burger-top");
    const bMid = document.getElementById("burger-mid");
    const bBot = document.getElementById("burger-bot");
    const header = document.getElementById("site-header");

    let lastY = window.scrollY;

    if (menuToggle && menu && navCard) {
      (window as any).__mobileNavCleanup?.();

      const closeMenu = () => {
        navCard.removeAttribute("data-mobile-open");
        menu.removeAttribute("data-mobile-open");
        document.body.style.overflow = "";

        bTop?.classList.remove("rotate-45", "translate-y-0");
        bTop?.classList.add("-translate-y-2");
        bMid?.classList.remove("opacity-0");
        bBot?.classList.remove("-rotate-45", "translate-y-0");
        bBot?.classList.add("translate-y-2");

        menuToggle.setAttribute("aria-expanded", "false");
      };

      const openMenu = () => {
        navCard.setAttribute("data-mobile-open", "true");
        menu.setAttribute("data-mobile-open", "true");
        document.body.style.overflow = "hidden";

        bTop?.classList.remove("-translate-y-2");
        bTop?.classList.add("rotate-45", "translate-y-0");
        bMid?.classList.add("opacity-0");
        bBot?.classList.remove("translate-y-2");
        bBot?.classList.add("-rotate-45", "translate-y-0");

        menuToggle.setAttribute("aria-expanded", "true");
      };

      const onToggleClick = () => {
        const isOpen = navCard.getAttribute("data-mobile-open") === "true";
        if (isOpen) closeMenu();
        else openMenu();
      };

      const onScroll = () => {
        if (!header || window.innerWidth >= 768) return;
        const isOpen = navCard.getAttribute("data-mobile-open") === "true";
        if (isOpen) return;
        const currentY = window.scrollY;
        if (currentY <= 8) {
          header.classList.remove("-translate-y-full");
          lastY = 0;
          return;
        }
        const shouldHide = currentY > lastY && currentY > 80;
        header.classList.toggle("-translate-y-full", shouldHide);
        lastY = currentY;
      };

      const onResize = () => {
        if (window.innerWidth >= 768) {
          closeMenu();
          header?.classList.remove("-translate-y-full");
        }
      };

      const onKeydown = (event: KeyboardEvent) => {
        if (event.key === "Escape") {
          const isOpen = navCard.getAttribute("data-mobile-open") === "true";
          if (isOpen) closeMenu();
        }
      };

      const onMenuClick = (event: Event) => {
        const target = event.target as HTMLElement | null;
        const link = target?.closest("a");
        if (!link) return;
        const href = link.getAttribute("href");
        const currentPath = window.location.pathname;
        const normalize = (p: string) => (p === "/" ? p : p.replace(/\/$/, ""));
        if (normalize(href || "") === normalize(currentPath)) {
          event.preventDefault();
          if (navCard.getAttribute("data-mobile-open") === "true") {
            closeMenu();
          }
        }
      };

      menuToggle.addEventListener("click", onToggleClick);
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onResize, { passive: true });
      document.addEventListener("keydown", onKeydown);
      menu.addEventListener("click", onMenuClick);

      (window as any).__mobileNavCleanup = () => {
        menuToggle.removeEventListener("click", onToggleClick);
        window.removeEventListener("scroll", onScroll);
        window.removeEventListener("resize", onResize);
        document.removeEventListener("keydown", onKeydown);
        menu.removeEventListener("click", onMenuClick);
      };
    }
  });
</script>

<style>
  #site-header {
    will-change: transform;
  }

  @media (max-width: 767px) {
    #site-header {
      padding-top: env(safe-area-inset-top, 0);
    }

    #nav-card {
      background: rgba(4, 9, 22, 0.82);
      -webkit-backdrop-filter: blur(10px);
      backdrop-filter: blur(10px);
    }

    #nav-card[data-mobile-open="true"] .nav-item {
      animation: navItemFadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
  }

  @keyframes navItemFadeIn {
    from {
      opacity: 0;
      transform: translateY(2rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .nav-item {
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
  }

  @media (min-width: 768px) {
    .nav-item {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
