---
interface Experience {
  company: string;
  role: string;
  period: string;
  type?: string;
  description: string;
  achievements: string[];
  technologies: string[];
  logo?: string;
}

const { item } = Astro.props as { item: Experience };
---

<article class="experience-card glass-card p-6 md:p-7">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <p class="text-xs uppercase tracking-[0.18em] text-cosmic-gold">{item.period}</p>
    <span class="experience-badge">{item.type === 'formation' ? 'Formation' : 'Expérience pro'}</span>
  </div>
  <h3 class="font-display text-4xl text-cosmic-gold md:text-5xl">{item.role}</h3>
  <p class="text-sm italic text-cosmic-pink md:text-base">{item.company}</p>
  <p class="muted mt-4 text-[1.02rem] leading-8">{item.description}</p>
  <ul class="experience-achievements mt-5 list-disc space-y-2 pl-5 muted">
    {item.achievements.map((achievement) => <li>{achievement}</li>)}
  </ul>
  <div class="mt-5 flex flex-wrap gap-2 text-xs">
    {item.technologies.map((tech) => <span class="experience-tech">{tech}</span>)}
  </div>
</article>
