---
import Card from "./ui/Card.astro";

interface Props {
  quote: string;
  author: string;
  role: string;
  company?: string;
  sourceLabel?: string;
  sourceUrl?: string;
  long?: boolean;
}

const { quote, author, role, company, sourceLabel, sourceUrl, long } =
  Astro.props as Props;
---

<Card as="article" hoverable shine class="testimonial-card mobile-card p-3.5 md:p-5">
  <p class="text-cosmic-gold text-xl leading-none">"</p>
  <blockquote
    class:list={[
      "mt-2 text-[0.9rem] md:text-base text-white/90 leading-relaxed testimonial-quote whitespace-pre-line",
      long && "line-clamp-4",
    ]}
  >
    {quote}
  </blockquote>
  {
    long && (
      <button
        type="button"
        class="testimonial-toggle tap-feedback mt-2 inline-flex min-h-11 items-center text-xs text-cosmic-gold hover:text-cosmic-pink transition"
      />
    )
  }
  <footer class="mt-4 border-t border-white/10 pt-3">
    <p class="text-sm font-semibold text-white">{author}</p>
    <p class="text-xs text-white/65">{role}{company ? ` · ${company}` : ""}</p>
    {
      sourceLabel && sourceUrl && (
        <a
          href={sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-flex text-xs text-cosmic-gold hover:text-cosmic-pink transition"
        >
          {sourceLabel}
        </a>
      )
    }
  </footer>
</Card>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLButtonElement>(".testimonial-toggle").forEach((btn) => {
      if (btn.dataset.bound === "1") return;
      const quote = btn.previousElementSibling as HTMLElement;
      const lang = document.documentElement.lang || "fr";
      const moreLabel = lang.startsWith("en") ? "Read more" : "Lire la suite";
      const lessLabel = lang.startsWith("en") ? "Show less" : "Réduire";

      btn.textContent = moreLabel;
      let expanded = false;

      btn.addEventListener("click", () => {
        expanded = !expanded;
        quote.classList.toggle("line-clamp-4", !expanded);
        btn.textContent = expanded ? lessLabel : moreLabel;
      });
      btn.dataset.bound = "1";
    });
  });
</script>
