---
interface Props {
  url: string;
  title?: string;
}

const { url, title = "Booking calendar" } = Astro.props as Props;
---

<iframe src={url} title={title} loading="lazy" class="booking-embed-iframe"
></iframe>

<style>
  .booking-embed-iframe {
    width: 100%;
    height: 100%;
    min-height: 560px;
    border-radius: 0.75rem;
    border: 1px solid #19008b3f;
    background: transparent;
    display: block;
  }
</style>
