---
interface Props {
  variant?: "pink" | "gold" | "teal" | "blue" | "tech" | "default" | "outline";
  class?: string;
}

const { variant = "default", class: className, ...rest } = Astro.props;

const baseClasses =
  "rounded-badge px-2 py-0.5 text-[10px] uppercase tracking-[0.12em] md:px-3 md:py-1 md:text-xs md:tracking-[0.15em]";

const variants = {
  tech: "border border-cosmic-gold/15 bg-linear-to-b from-[#0a0f22]/80 to-[#0e162d]/70 text-[#efe7c4] transition-all hover:-translate-y-0.5 hover:border-cosmic-gold/40 hover:from-[#1a2242]/90 hover:to-[#121a31]/80",
  default: "bg-slate-900/60 text-cosmic-pink",
  outline: "border border-cosmic-gold/30 text-cosmic-gold bg-transparent",
  pink: "bg-cosmic-pink/20 text-cosmic-pink border border-cosmic-pink/30",
  gold: "bg-cosmic-gold/20 text-cosmic-gold border border-cosmic-gold/30",
  teal: "bg-[#8fe9ef]/20 text-[#8fe9ef] border border-[#8fe9ef]/30",
  blue: "bg-[#8ab4ff]/20 text-[#8ab4ff] border border-[#8ab4ff]/30",
};
---

<span class:list={[baseClasses, variants[variant], className]} {...rest}>
  <slot />
</span>
