---
const {
  as: Component = Astro.props.href ? "a" : "div",
  href,
  class: className,
  interactive = false,
  hoverable = interactive,
  shine = false,
  ...rest
} = Astro.props;

const baseClasses = "glass-card card-shell";
const hoverableClasses = hoverable ? "card-hoverable" : "";

const interactiveClasses = interactive ? "card-interactive focus-ring" : "";

const elementProps = Component === "a" ? { href } : {};
---

<Component
  class:list={[
    baseClasses,
    hoverableClasses,
    interactiveClasses,
    shine && "shine-effect",
    className,
  ]}
  {...elementProps}
  {...rest}
>
  <slot />
</Component>
