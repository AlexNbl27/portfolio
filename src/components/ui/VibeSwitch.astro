---
interface Props {
  id?: string;
  locale?: "fr" | "en";
}

const { id = "vibe-switch", locale = "fr" } = Astro.props;
const isEn = locale === "en";
---

<svg class="absolute w-0 h-0 overflow-hidden" aria-hidden="true">
  <defs>
    <filter id="magma-morph" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence type="fractalNoise" baseFrequency="0.018" numOctaves="3" seed="5" result="noise"></feTurbulence>
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="14" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap>
    </filter>
  </defs>
</svg>

<div class="flex items-center">
  <label class="vibe-switch relative inline-flex h-14 w-64 cursor-pointer select-none items-center overflow-hidden rounded-full p-[3px] transition-all hover:scale-105 active:scale-95 border border-white/10 bg-slate-900/80 backdrop-blur-md group">
    <input type="checkbox" id={id} class="peer sr-only" />

    <div class="track-off absolute inset-0 rounded-full transition-opacity duration-700 peer-checked:opacity-0">
      <div class="nebula-off absolute inset-0 rounded-full"></div>
      <div class="stars"></div>
    </div>

    <div class="absolute inset-0 rounded-full overflow-hidden opacity-0 transition-opacity duration-700 peer-checked:opacity-100">
      <div class="magma-base absolute inset-0"></div>
      <div class="magma-blob magma-blob-violet"></div>
      <div class="magma-blob magma-blob-1"></div>
      <div class="magma-blob magma-blob-2"></div>
      <div class="magma-blob magma-blob-3"></div>
    </div>

    <span class="switch-label-off absolute right-6 z-10 text-xs font-bold tracking-widest uppercase text-white transition-all duration-500 whitespace-nowrap peer-checked:opacity-0 peer-checked:translate-x-4">{isEn ? "enable ai" : "activer l'ia"}</span>
    <span class="switch-label-on absolute left-6 z-10 text-xs font-bold tracking-widest uppercase text-slate-900 opacity-0 transition-all duration-500 whitespace-nowrap -translate-x-4 peer-checked:opacity-100 peer-checked:translate-x-0">{isEn ? "vibe code on" : "vibe code activé"}</span>

    <div class="switch-knob absolute left-1.5 top-1.5 h-11 w-11 rounded-full bg-white transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] peer-checked:left-[calc(100%-48px)] shadow-[0_0_20px_rgba(255,255,255,0.9)] z-20"><div class="absolute inset-[30%] rounded-full bg-slate-100/50"></div></div>
    <div class="outer-glow absolute inset-0 -z-10 rounded-full opacity-0 blur-2xl transition-opacity duration-700 peer-checked:opacity-70"></div>
  </label>
</div>

<style>
/* existing styles preserved */
  .track-off {background: radial-gradient(ellipse at 55% 45%, #0f0a1e 0%, #04040f 100%);} .nebula-off {background:radial-gradient(ellipse 65% 90% at 15% 50%,rgba(100,0,220,.22) 0%,transparent 70%),radial-gradient(ellipse 55% 70% at 85% 50%,rgba(0,50,200,.14) 0%,transparent 70%);animation: nebula-breathe 6s ease-in-out infinite;} @keyframes nebula-breathe {0%,100% {opacity:.6;}50%{opacity:1;}}
  .stars {position:absolute;top:13px;left:0;width:2px;height:2px;border-radius:50%;background:white;box-shadow:18px 5px 0 0 rgba(255,255,255,.9),40px 16px 0 0 rgba(255,255,255,.5),60px 3px 0 0 rgba(255,255,255,.8),82px 19px 0 0 rgba(255,255,255,.6),104px 9px 0 0 rgba(255,255,255,.95),126px 22px 0 0 rgba(255,255,255,.4),148px 5px 0 0 rgba(255,255,255,.7),170px 17px 0 0 rgba(255,255,255,.85),202px 11px 0 0 rgba(255,255,255,.55),230px 6px 0 0 rgba(255,255,255,.65),30px 27px 0 0 rgba(255,255,255,.3),70px 29px 0 0 rgba(255,255,255,.5),112px 25px 0 0 rgba(255,255,255,.35),188px 28px 0 0 rgba(255,255,255,.6),242px 23px 0 0 rgba(200,180,255,.5);animation: twinkle 4s ease-in-out infinite;} @keyframes twinkle {0%,100%{opacity:.35;}25%{opacity:1;}55%{opacity:.55;}80%{opacity:.9;}}
  .magma-base {background: radial-gradient(ellipse at 50% 50%, #180010 0%, #250400 100%);} .magma-blob {position:absolute;border-radius:40%;will-change:transform;filter:url(#magma-morph) blur(9px);} .magma-blob-violet {width:200%;height:200%;top:-50%;left:-50%;background:radial-gradient(ellipse at 50% 50%,#8b00ff 0%,#3a006e 45%,transparent 65%);animation:drift-violet 9s ease-in-out infinite;opacity:.65;filter:blur(16px);} .magma-blob-1 {width:160%;height:160%;top:-30%;left:-30%;background:radial-gradient(ellipse at 45% 55%,#ff3300 0%,#bb1500 40%,transparent 68%);animation:drift1 4.3s ease-in-out infinite;mix-blend-mode:screen;} .magma-blob-2 {width:150%;height:150%;top:-25%;left:-15%;background:radial-gradient(ellipse at 55% 45%,#ff8800 0%,#ff4400 45%,transparent 68%);animation:drift2 5.9s ease-in-out infinite;mix-blend-mode:screen;opacity:.9;} .magma-blob-3 {width:110%;height:110%;top:-5%;left:-5%;background:radial-gradient(ellipse at 50% 50%,#ffcc00 0%,#ff8800 35%,transparent 62%);animation:drift3 3.1s ease-in-out infinite;mix-blend-mode:screen;opacity:.55;}
  @keyframes drift-violet {0%,100%{transform:translate(0%,0%) scale(1);}25%{transform:translate(5%,-8%) scale(1.06);}50%{transform:translate(-8%,5%) scale(.94);}75%{transform:translate(4%,9%) scale(1.03);}} @keyframes drift1 {0%,100%{transform:translate(0%,0%) scale(1);}20%{transform:translate(7%,-10%) scale(1.04);}45%{transform:translate(-6%,8%) scale(.96);}70%{transform:translate(11%,4%) scale(1.07);}} @keyframes drift2 {0%,100%{transform:translate(0%,0%) scale(1);}30%{transform:translate(-9%,9%) scale(1.08);}55%{transform:translate(8%,-7%) scale(.93);}80%{transform:translate(-4%,-11%) scale(1.03);}} @keyframes drift3 {0%,100%{transform:translate(0%,0%) scale(1);}35%{transform:translate(9%,11%) scale(1.12);}65%{transform:translate(-7%,-5%) scale(.94);}}
  .outer-glow {background: radial-gradient(ellipse at center, #ff5500 0%, #9900cc 55%, transparent 75%);} @media (max-width: 480px){.vibe-switch{width:14.5rem;height:3rem;}.switch-label-off,.switch-label-on{font-size:.55rem;letter-spacing:.16em;}}
</style>
