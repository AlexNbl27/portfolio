---
interface Props {
  id?: string;
  locale?: "fr" | "en";
}

const { id = "vibe-switch", locale = "fr" } = Astro.props;
const isEn = locale === "en";
---

<svg class="absolute w-0 h-0 overflow-hidden" aria-hidden="true">
  <defs>
    <filter id="magma-morph" x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.018"
        numOctaves="3"
        seed="5"
        result="noise"></feTurbulence>
      <feDisplacementMap
        in="SourceGraphic"
        in2="noise"
        scale="14"
        xChannelSelector="R"
        yChannelSelector="G"></feDisplacementMap>
    </filter>
  </defs>
</svg>

<div class="flex items-center">
  <label
    class="vibe-switch relative inline-flex cursor-pointer select-none items-center overflow-hidden rounded-full border border-white/10 bg-slate-900/80 p-[3px] backdrop-blur-md transition-all hover:scale-105 active:scale-95 group"
  >
    <input type="checkbox" id={id} class="peer sr-only" />

    <div
      class="track-off absolute inset-0 rounded-full transition-opacity duration-700 peer-checked:opacity-0"
    >
      <div class="nebula-off absolute inset-0 rounded-full"></div>
      <div class="stars"></div>
    </div>

    <div
      class="absolute inset-0 rounded-full overflow-hidden opacity-0 transition-opacity duration-700 peer-checked:opacity-100"
    >
      <div class="magma-base absolute inset-0"></div>
      <div class="magma-blob magma-blob-violet"></div>
      <div class="magma-blob magma-blob-1"></div>
      <div class="magma-blob magma-blob-2"></div>
      <div class="magma-blob magma-blob-3"></div>
    </div>

    <span
      class="switch-label-off absolute right-6 z-10 text-xs font-bold tracking-widest uppercase text-white transition-all duration-500 whitespace-nowrap peer-checked:opacity-0 peer-checked:translate-x-4"
      >{isEn ? "enable ai" : "activer l'ia"}</span
    >
    <span
      class="switch-label-on absolute left-6 z-10 text-xs font-bold tracking-widest uppercase text-slate-900 opacity-0 transition-all duration-500 whitespace-nowrap -translate-x-4 peer-checked:opacity-100 peer-checked:translate-x-0"
      >{isEn ? "vibe code on" : "vibe code activé"}</span
    >

    <div
      class="switch-knob absolute rounded-full bg-white shadow-[0_0_20px_rgba(255,255,255,0.9)] transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] z-20"
    >
      <div class="absolute inset-[30%] rounded-full bg-slate-100/50"></div>
    </div>
    <div
      class="outer-glow absolute inset-0 -z-10 rounded-full opacity-0 blur-2xl transition-opacity duration-700 peer-checked:opacity-70"
    >
    </div>
  </label>
</div>
