---
interface Props {
  id?: string;
}

const { id = "vibe-switch" } = Astro.props;
---

<div class="flex items-center">
  <label class="relative inline-flex h-14 w-64 cursor-pointer items-center overflow-hidden rounded-full p-[3px] transition-all hover:scale-105 active:scale-95 shadow-[0_0_30px_rgba(246,212,13,0.15)] border border-white/10 bg-slate-900/80 backdrop-blur-md group">
    <input type="checkbox" id={id} class="peer sr-only" />
    
    <!-- Track Gradient Background -->
    <div class="absolute inset-0 rounded-full bg-slate-800 transition-all duration-500 peer-checked:bg-gradient-to-r peer-checked:from-cosmic-gold peer-checked:via-cosmic-pink peer-checked:to-cyan-400 peer-checked:bg-[length:200%_auto] peer-checked:animate-vibe-gradient"></div>

    <!-- Labels Container -->
    <div class="relative h-full w-full z-10 flex items-center justify-center">
      <!-- Label when OFF (placed right) -->
      <span class="absolute right-6 text-sm font-bold tracking-wider text-cosmic-gold transition-all duration-500 whitespace-nowrap peer-checked:opacity-0 peer-checked:translate-x-4">
        activer l'ia
      </span>
      
      <!-- Label when ON (placed left) -->
      <span class="absolute left-6 text-sm font-bold tracking-wider text-white opacity-0 transition-all duration-500 whitespace-nowrap -translate-x-4 peer-checked:opacity-100 peer-checked:translate-x-0">
        vibe code activé
      </span>
    </div>
    
    <!-- Knob -->
    <div class="absolute left-1.5 top-1.5 h-11 w-11 rounded-full bg-white transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] peer-checked:left-[calc(100%-48px)] shadow-[0_0_20px_rgba(255,255,255,0.9)] z-20">
       <!-- Minimal icon / dot on knob -->
       <div class="absolute inset-[30%] rounded-full bg-slate-100/50"></div>
    </div>

    <!-- Glow effect behind -->
    <div class="absolute inset-0 -z-10 rounded-full opacity-0 blur-2xl transition-opacity duration-500 peer-checked:opacity-40 bg-gradient-to-r from-cosmic-gold via-cosmic-pink to-cyan-400 bg-[length:200%_auto] animate-vibe-gradient"></div>
  </label>
</div>

<style>
  @keyframes vibe-gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .animate-vibe-gradient {
    animation: vibe-gradient 3s ease infinite;
  }
</style>
