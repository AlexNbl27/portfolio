---
import { Icon } from "astro-icon/components";

const {
  as: Component = Astro.props.href ? "a" : "button",
  variant = "primary",
  class: className,
  icon,
  ...rest
} = Astro.props;

const baseClasses =
  "focus-ring tap-feedback inline-flex min-h-11 gap-2 items-center justify-center rounded-btn px-3.5 py-2 text-[10px] font-bold uppercase tracking-[0.13em] transition duration-200 outline-none md:px-4 md:py-2 md:text-xs md:tracking-[0.15em]";

const variants = {
  primary: "bg-cosmic-gold text-black hover:brightness-110",
  ghost:
    "border border-cosmic-gold/35 text-[#fff1b3] bg-linear-to-br from-[#0b1023]/80 to-[#0d1429]/70 hover:-translate-y-[1px] hover:shadow-[0_12px_28px_rgba(246,212,13,0.24)]",
  outline:
    "border border-cosmic-gold/30 text-cosmic-gold hover:border-cosmic-gold",
};
---

<Component
  class:list={[
    baseClasses,
    variants[variant as keyof typeof variants],
    className,
  ]}
  {...rest}
>
  {icon && <Icon name={icon} class="w-4 h-4" />}
  <slot />
</Component>
