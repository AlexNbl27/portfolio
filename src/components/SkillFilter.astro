---
const { categories } = Astro.props as { categories: string[] };
---

<div class="mb-4 mt-8 flex flex-wrap gap-2" role="toolbar" aria-label="Filtrer les compétences">
  <button class="focus-ring skill-filter rounded-full border border-cosmic-gold/50 px-4 py-2 text-xs uppercase tracking-[0.2em]" data-category="all">Toutes</button>
  {categories.map((category) => (
    <button class="focus-ring skill-filter rounded-full border border-cosmic-gold/20 px-4 py-2 text-xs uppercase tracking-[0.2em]" data-category={category}>{category}</button>
  ))}
</div>
