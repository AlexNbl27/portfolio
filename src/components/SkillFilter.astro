---
import SearchBadge from "./ui/SearchBadge.astro";
import FilterBadge from "./ui/FilterBadge.astro";
import type { Locale } from "../i18n/config";

const { categories, locale = "fr" } = Astro.props as {
  categories: string[];
  locale?: Locale;
};
const isEn = locale === "en";

const categoryLabelsEn: Record<string, string> = {
  "Mobile & logiciel": "Mobile & software",
  "Développement web": "Web development",
  "Backend & frameworks": "Backend & frameworks",
  "Base de données": "Databases",
  "DevOps & outils": "DevOps & tools",
  "Automatisme & industrie": "Automation & industry",
  "AI & Agentic Coding": "AI & Agentic coding",
};
---

<div
  class="filter-toolbar mb-8 pt-4"
  role="toolbar"
  aria-label={isEn ? "Filter skills" : "Filtrer les compétences"}
>
  <FilterBadge class="focus-ring skill-filter" active data-category="all"
    >{isEn ? "All" : "Toutes"}</FilterBadge
  >
  {
    categories.map((category) => (
      <FilterBadge class="focus-ring skill-filter" data-category={category}>
        {isEn ? (categoryLabelsEn[category] ?? category) : category}
      </FilterBadge>
    ))
  }
  <SearchBadge locale={locale} />
</div>
