---
import SearchBadge from './ui/SearchBadge.astro';
import type { Locale } from '../i18n/config';

const { categories, locale = 'fr' } = Astro.props as { categories: string[]; locale?: Locale };
const isEn = locale === 'en';

const categoryLabelsEn: Record<string, string> = {
  "Mobile & logiciel": "Mobile & software",
  "Développement web": "Web development",
  "Backend & frameworks": "Backend & frameworks",
  "Base de données": "Databases",
  "DevOps & outils": "DevOps & tools",
  "Automatisme & industrie": "Automation & industry",
  "AI & Agentic Coding": "AI & Agentic coding",
};

---

<div class="mb-8 pt-4 flex flex-wrap items-center gap-3" role="toolbar" aria-label={isEn ? 'Filter skills' : 'Filtrer les compétences'}>
  <button class="focus-ring skill-filter rounded-full border border-cosmic-gold/50 px-4 py-2 text-xs uppercase tracking-[0.2em] transition-all" data-category="all">{isEn ? 'All' : 'Toutes'}</button>
  {categories.map((category) => (
    <button class="focus-ring skill-filter rounded-full border border-cosmic-gold/20 px-4 py-2 text-xs uppercase tracking-[0.2em] transition-all" data-category={category}>{isEn ? (categoryLabelsEn[category] ?? category) : category}</button>
  ))}
  <SearchBadge locale={locale} />
</div>
