---
import SearchBadge from './ui/SearchBadge.astro';
const { categories } = Astro.props as { categories: string[] };
---

<div
  class="mb-8 pt-4 flex flex-wrap items-center gap-3"
  role="toolbar"
  aria-label="Filtrer les compétences"
>
  <button
    class="focus-ring skill-filter rounded-full border border-cosmic-gold/50 px-4 py-2 text-xs uppercase tracking-[0.2em] transition-all"
    data-category="all">Toutes</button
  >
  {
    categories.map((category) => (
      <button
        class="focus-ring skill-filter rounded-full border border-cosmic-gold/20 px-4 py-2 text-xs uppercase tracking-[0.2em] transition-all"
        data-category={category}
      >
        {category}
      </button>
    ))
  }
  
  <SearchBadge />
</div>
