---
import Card from "./ui/Card.astro";

interface SkillCardProps {
  title: string;
  description: string;
}

const { title, description } = Astro.props as SkillCardProps;
---

<Card as="article" class="featured-soft-skill p-5">
  <h3 class="font-display text-3xl text-cosmic-gold">{title}</h3>
  <p class="muted mt-2">{description}</p>
</Card>
