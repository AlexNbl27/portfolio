---
interface Props {
  softSkillsUrl: string;
  skillsUrl: string;
  isEn: boolean;
}
const { softSkillsUrl, skillsUrl, isEn } = Astro.props;
---

<!-- Desktop: interactive rocket -->
<div class="rocket-wrapper" id="rocket-wrapper">
  <div class="rocket-scene" id="rocket-scene">

    <svg
      id="rocket-svg"
      viewBox="0 0 800 540"
      xmlns="http://www.w3.org/2000/svg"
      class="rocket-svg"
      aria-hidden="true"
    >
      <defs>
        <!-- Body gradient -->
        <linearGradient id="bodyGrad" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%"   stop-color="#090f24"/>
          <stop offset="40%"  stop-color="#1a2347"/>
          <stop offset="60%"  stop-color="#1a2347"/>
          <stop offset="100%" stop-color="#090f24"/>
        </linearGradient>

        <!-- Nose cone -->
        <linearGradient id="noseGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="#2c2a5f"/>
          <stop offset="100%" stop-color="#0f1735"/>
        </linearGradient>

        <!-- Porthole -->
        <radialGradient id="portholeGrad" cx="38%" cy="35%">
          <stop offset="0%"   stop-color="#5ba3d9"/>
          <stop offset="50%"  stop-color="#1a4a7a"/>
          <stop offset="100%" stop-color="#050e22"/>
        </radialGradient>

        <!-- Flame main -->
        <radialGradient id="flameGrad" cx="50%" cy="15%">
          <stop offset="0%"   stop-color="#ffffff"/>
          <stop offset="22%"  stop-color="#f6d40d"/>
          <stop offset="58%"  stop-color="#ff7d2b"/>
          <stop offset="100%" stop-color="rgba(255,100,0,0)"/>
        </radialGradient>

        <!-- Flame core -->
        <radialGradient id="flameCoreGrad" cx="50%" cy="5%">
          <stop offset="0%"   stop-color="#ffffff"/>
          <stop offset="45%"  stop-color="#f6d40d"/>
          <stop offset="100%" stop-color="rgba(246,212,13,0)"/>
        </radialGradient>

        <!-- Left wing: pink -->
        <linearGradient id="lwGrad" x1="1" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="#f2b4df" stop-opacity="0.9"/>
          <stop offset="100%" stop-color="#f2b4df" stop-opacity="0.1"/>
        </linearGradient>

        <!-- Right wing: gold -->
        <linearGradient id="rwGrad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%"   stop-color="#f6d40d" stop-opacity="0.9"/>
          <stop offset="100%" stop-color="#f6d40d" stop-opacity="0.1"/>
        </linearGradient>

        <!-- Glow filters -->
        <filter id="glow-pink" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="14" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glow-gold" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="14" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="flame-blur" x="-60%" y="-10%" width="220%" height="140%">
          <feGaussianBlur stdDeviation="9"/>
        </filter>
        <filter id="body-glow" x="-10%" y="-5%" width="120%" height="115%">
          <feDropShadow dx="0" dy="6" stdDeviation="16" flood-color="#f6d40d" flood-opacity="0.18"/>
        </filter>
        <filter id="nose-tip-glow" x="-200%" y="-200%" width="500%" height="500%">
          <feGaussianBlur stdDeviation="4"/>
        </filter>
      </defs>

      <!-- ═══════════════ LEFT WING (Soft Skills) ═══════════════ -->
      <g
        id="left-wing"
        class="wing"
        role="button"
        tabindex="0"
        aria-label={isEn ? "Soft Skills" : "Soft Skills"}
        data-url={softSkillsUrl}
        data-dir="left"
      >
        <!-- Wing fill -->
        <path
          d="M 315,182 L 55,168 L 18,520 L 315,372 Z"
          fill="url(#lwGrad)"
          stroke="#f2b4df"
          stroke-width="1.5"
          class="wing-fill lw-fill"
        />
        <!-- Hover glow overlay (always present, opacity toggled) -->
        <path
          d="M 315,182 L 55,168 L 18,520 L 315,372 Z"
          fill="#f2b4df"
          class="wing-glow lw-glow"
        />
        <!-- Leading edge accent -->
        <path d="M 315,182 L 55,168" stroke="#f2b4df" stroke-width="2.5" opacity="0.55" stroke-linecap="round"/>
        <!-- Trailing edge -->
        <path d="M 315,372 L 18,520" stroke="#f2b4df" stroke-width="1" opacity="0.2" stroke-linecap="round"/>
        <!-- Rib lines -->
        <path d="M 295,210 L 75,390" stroke="#f2b4df" stroke-width="0.6" opacity="0.2"/>
        <path d="M 295,275 L 48,445" stroke="#f2b4df" stroke-width="0.6" opacity="0.15"/>
        <!-- Tip dot -->
        <circle cx="18" cy="520" r="3.5" fill="#f2b4df" opacity="0.4" class="wing-tip-dot"/>
      </g>

      <!-- ═══════════════ RIGHT WING (Technical Skills) ═══════════════ -->
      <g
        id="right-wing"
        class="wing"
        role="button"
        tabindex="0"
        aria-label={isEn ? "Technical Skills" : "Compétences techniques"}
        data-url={skillsUrl}
        data-dir="right"
      >
        <path
          d="M 485,182 L 745,168 L 782,520 L 485,372 Z"
          fill="url(#rwGrad)"
          stroke="#f6d40d"
          stroke-width="1.5"
          class="wing-fill rw-fill"
        />
        <path
          d="M 485,182 L 745,168 L 782,520 L 485,372 Z"
          fill="#f6d40d"
          class="wing-glow rw-glow"
        />
        <path d="M 485,182 L 745,168" stroke="#f6d40d" stroke-width="2.5" opacity="0.55" stroke-linecap="round"/>
        <path d="M 485,372 L 782,520" stroke="#f6d40d" stroke-width="1" opacity="0.2" stroke-linecap="round"/>
        <path d="M 505,210 L 725,390" stroke="#f6d40d" stroke-width="0.6" opacity="0.2"/>
        <path d="M 505,275 L 752,445" stroke="#f6d40d" stroke-width="0.6" opacity="0.15"/>
        <circle cx="782" cy="520" r="3.5" fill="#f6d40d" opacity="0.4" class="wing-tip-dot"/>
      </g>

      <!-- ═══════════════ ROCKET BODY ═══════════════ -->
      <g id="rocket-body" filter="url(#body-glow)">
        <!-- Main body -->
        <rect x="315" y="144" width="170" height="242" rx="5" fill="url(#bodyGrad)"/>

        <!-- Nose cone -->
        <path d="M 400,22 L 315,149 L 485,149 Z" fill="url(#noseGrad)"/>
        <!-- Nose highlight -->
        <path d="M 400,22 L 358,120 L 373,120 Z" fill="white" opacity="0.06"/>

        <!-- Nose tip glow -->
        <circle cx="400" cy="26" r="5" fill="#f6d40d" opacity="0.3" filter="url(#nose-tip-glow)"/>
        <circle cx="400" cy="26" r="2.5" fill="#f6d40d" opacity="0.8"/>

        <!-- Gold accent stripes -->
        <rect x="315" y="144" width="170" height="3"   rx="1.5" fill="#f6d40d" opacity="0.75"/>
        <rect x="315" y="383" width="170" height="2"   rx="1"   fill="#f6d40d" opacity="0.45"/>
        <rect x="315" y="222" width="170" height="1.5"          fill="#f6d40d" opacity="0.15"/>
        <rect x="315" y="322" width="170" height="1.5"          fill="#f6d40d" opacity="0.15"/>

        <!-- Side rails -->
        <rect x="315" y="144" width="3"   height="242" rx="1.5" fill="#f6d40d" opacity="0.2"/>
        <rect x="482" y="144" width="3"   height="242" rx="1.5" fill="#f6d40d" opacity="0.2"/>

        <!-- Porthole -->
        <circle cx="400" cy="268" r="41" fill="#050e22" stroke="#f6d40d" stroke-width="2.5"/>
        <circle cx="400" cy="268" r="36" fill="url(#portholeGrad)"/>
        <ellipse cx="386" cy="255" rx="11" ry="6.5" fill="white" opacity="0.1" transform="rotate(-30 386 255)"/>
        <circle  cx="388"  cy="254" r="3.5" fill="white" opacity="0.18"/>

        <!-- Porthole rivets -->
        <circle cx="362" cy="235" r="3" fill="#f6d40d" opacity="0.45"/>
        <circle cx="438" cy="235" r="3" fill="#f6d40d" opacity="0.45"/>
        <circle cx="362" cy="301" r="3" fill="#f6d40d" opacity="0.45"/>
        <circle cx="438" cy="301" r="3" fill="#f6d40d" opacity="0.45"/>

        <!-- Nozzle block -->
        <path d="M 348,382 L 452,382 L 440,458 L 360,458 Z"
              fill="#060c1e" stroke="#f6d40d" stroke-width="1" stroke-opacity="0.35"/>
        <rect  x="375" y="412" width="50" height="6"  rx="3" fill="#131d38"/>
        <rect  x="382" y="423" width="36" height="9"  rx="4.5"
               fill="#0a1428" stroke="#f6d40d" stroke-width="0.7" stroke-opacity="0.35"/>
        <circle cx="400" cy="445" r="5" fill="#f6d40d" opacity="0.25"/>
      </g>

      <!-- ═══════════════ FLAME ═══════════════ -->
      <g id="flame-group">
        <!-- Bloom -->
        <ellipse cx="400" cy="500" rx="30" ry="54"
                 fill="#ff6b2b" opacity="0.28" filter="url(#flame-blur)" class="flame-bloom"/>
        <!-- Main flame -->
        <ellipse cx="400" cy="490" rx="17" ry="44"
                 fill="url(#flameGrad)" class="flame-main"/>
        <!-- Core -->
        <ellipse cx="400" cy="470" rx="7.5" ry="22"
                 fill="url(#flameCoreGrad)" class="flame-core"/>
        <!-- Side petals -->
        <ellipse cx="385" cy="496" rx="9" ry="29"
                 fill="#ff8c3a" opacity="0.52" class="flame-side-l"/>
        <ellipse cx="415" cy="496" rx="9" ry="29"
                 fill="#ff8c3a" opacity="0.52" class="flame-side-r"/>
      </g>
    </svg>

    <!-- HTML label overlays (pointer-events: none so SVG handles clicks) -->
    <div class="wing-label left-label" id="left-label" aria-hidden="true">
      <span class="wl-tag">{isEn ? "Human" : "Humain"}</span>
      <span class="wl-title">Soft Skills</span>
      <span class="wl-arrow" aria-hidden="true">←</span>
    </div>

    <div class="wing-label right-label" id="right-label" aria-hidden="true">
      <span class="wl-arrow" aria-hidden="true">→</span>
      <span class="wl-title">{isEn ? "Technical" : "Technique"}</span>
      <span class="wl-tag">{isEn ? "Skills" : "Compétences"}</span>
    </div>
  </div>

  <p class="rocket-hint" id="rocket-hint">
    {isEn ? "Click a wing · the rocket will take you there" : "Clique sur une aile · la fusée t'emmène"}
  </p>
</div>


<style>

  /* ─── Layout ─── */
  .rocket-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .rocket-scene {
    position: relative;
    width: 100%;
    max-width: 780px;
    /* Maintain SVG aspect ratio 800:540 */
    aspect-ratio: 800 / 540;
  }

  .rocket-svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  /* ─── Wing base state ─── */
  .wing {
    cursor: pointer;
    outline: none;
  }

  .wing-glow   { opacity: 0;    transition: opacity 0.35s ease; }
  .wing-fill   { transition: filter 0.35s ease; }
  .wing-tip-dot { transition: opacity 0.35s ease, r 0.35s ease; }

  /* ─── Left wing hover ─── */
  #left-wing:hover .lw-glow,
  #left-wing:focus-visible .lw-glow  { opacity: 0.07; }

  #left-wing:hover .lw-fill,
  #left-wing:focus-visible .lw-fill  { filter: url(#glow-pink) brightness(1.35); }

  #left-wing:hover .wing-tip-dot,
  #left-wing:focus-visible .wing-tip-dot { opacity: 0.9; }

  /* ─── Right wing hover ─── */
  #right-wing:hover .rw-glow,
  #right-wing:focus-visible .rw-glow  { opacity: 0.07; }

  #right-wing:hover .rw-fill,
  #right-wing:focus-visible .rw-fill  { filter: url(#glow-gold) brightness(1.35); }

  #right-wing:hover .wing-tip-dot,
  #right-wing:focus-visible .wing-tip-dot { opacity: 0.9; }

  /* ─── Flame animations ─── */
  .flame-main {
    transform-box: fill-box;
    transform-origin: center top;
    animation: flicker 0.11s ease-in-out infinite alternate;
  }
  .flame-core {
    transform-box: fill-box;
    transform-origin: center top;
    animation: flicker 0.08s ease-in-out infinite alternate;
  }
  .flame-side-l {
    transform-box: fill-box;
    transform-origin: center top;
    animation: flicker-l 0.13s ease-in-out infinite alternate;
  }
  .flame-side-r {
    transform-box: fill-box;
    transform-origin: center top;
    animation: flicker-r 0.10s ease-in-out infinite alternate;
  }
  .flame-bloom {
    transform-box: fill-box;
    transform-origin: center top;
    animation: flicker 0.15s ease-in-out infinite alternate;
  }

  @keyframes flicker {
    from { transform: scaleX(0.82) scaleY(0.92); opacity: 0.88; }
    to   { transform: scaleX(1.18) scaleY(1.08); opacity: 1; }
  }
  @keyframes flicker-l {
    from { transform: scaleX(0.75) scaleY(0.88) rotate(-4deg); }
    to   { transform: scaleX(1.25) scaleY(1.12) rotate(2deg); }
  }
  @keyframes flicker-r {
    from { transform: scaleX(0.75) scaleY(0.88) rotate(4deg); }
    to   { transform: scaleX(1.25) scaleY(1.12) rotate(-2deg); }
  }

  /* ─── Launch animations ─── */
  .rocket-scene.launching-left {
    animation: launch-left 0.72s cubic-bezier(0.4, 0, 0.15, 1) forwards;
  }
  .rocket-scene.launching-right {
    animation: launch-right 0.72s cubic-bezier(0.4, 0, 0.15, 1) forwards;
  }

  @keyframes launch-left {
    0%   { transform: translateY(0)    rotate(0deg);   }
    12%  { transform: translateY(12px) rotate(-2.5deg); }
    28%  { transform: translateY(-14px) rotate(-6deg); }
    100% { transform: translateY(-130vh) rotate(-10deg); }
  }
  @keyframes launch-right {
    0%   { transform: translateY(0)    rotate(0deg);  }
    12%  { transform: translateY(12px) rotate(2.5deg); }
    28%  { transform: translateY(-14px) rotate(6deg); }
    100% { transform: translateY(-130vh) rotate(10deg); }
  }

  /* ─── HTML wing label overlays ─── */
  .wing-label {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
    /* frosted pill background for readability */
    background: rgba(4, 9, 22, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 10px 18px 12px;
    border-radius: 999px;
    border: 1px solid transparent;
  }

  .left-label {
    left: 22%;
    top: 57%;
    transform: translate(-50%, -50%) rotate(-20deg);
    opacity: 0.72;
    border-color: rgba(242, 180, 223, 0.2);
  }
  .left-label.hovered {
    opacity: 1;
    border-color: rgba(242, 180, 223, 0.55);
    transform: translate(-50%, -50%) rotate(-20deg) scale(1.06);
  }

  .right-label {
    left: 78%;
    top: 57%;
    transform: translate(-50%, -50%) rotate(20deg);
    opacity: 0.72;
    border-color: rgba(246, 212, 13, 0.2);
  }
  .right-label.hovered {
    opacity: 1;
    border-color: rgba(246, 212, 13, 0.55);
    transform: translate(-50%, -50%) rotate(20deg) scale(1.06);
  }

  .wl-tag {
    font-family: var(--font-body, Manrope, sans-serif);
    font-size: 9px;
    letter-spacing: 4px;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .wl-title {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: clamp(18px, 3vw, 30px);
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    text-shadow: 0 2px 12px rgba(0,0,0,0.6);
  }
  .wl-arrow {
    font-size: 13px;
    opacity: 0.7;
    margin-top: 1px;
  }

  .left-label  .wl-tag,
  .left-label  .wl-title,
  .left-label  .wl-arrow  { color: #f2b4df; }

  .right-label .wl-tag,
  .right-label .wl-title,
  .right-label .wl-arrow  { color: #f6d40d; }

  /* ─── Hint text ─── */
  .rocket-hint {
    font-family: var(--font-body, Manrope, sans-serif);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.28);
    margin-top: 8px;
    user-select: none;
    transition: opacity 0.3s;
  }


  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .flame-main, .flame-core,
    .flame-side-l, .flame-side-r,
    .flame-bloom { animation: none; }
    .rocket-scene.launching-left,
    .rocket-scene.launching-right { animation: none; }
  }
</style>

<script define:vars={{ softSkillsUrl, skillsUrl }}>
  function initRocket() {
    const leftWing  = document.getElementById('left-wing');
    const rightWing = document.getElementById('right-wing');
    if (!leftWing || !rightWing) return;

    const leftLabel  = document.getElementById('left-label');
    const rightLabel = document.getElementById('right-label');
    const scene      = document.getElementById('rocket-scene');
    const hint       = document.getElementById('rocket-hint');

    function setHover(label, on) {
      label?.classList.toggle('hovered', on);
    }

    leftWing.addEventListener('mouseenter', () => setHover(leftLabel, true));
    leftWing.addEventListener('mouseleave', () => setHover(leftLabel, false));
    leftWing.addEventListener('focus',      () => setHover(leftLabel, true));
    leftWing.addEventListener('blur',       () => setHover(leftLabel, false));

    rightWing.addEventListener('mouseenter', () => setHover(rightLabel, true));
    rightWing.addEventListener('mouseleave', () => setHover(rightLabel, false));
    rightWing.addEventListener('focus',      () => setHover(rightLabel, true));
    rightWing.addEventListener('blur',       () => setHover(rightLabel, false));

    let launched = false;

    function launch(url, dir) {
      if (launched) return;
      launched = true;

      if (hint) hint.style.opacity = '0';
      scene?.classList.add(`launching-${dir}`);

      const overlay = document.getElementById('page-transition-overlay');

      // Fade overlay IN after rocket starts lifting (~350ms)
      setTimeout(() => {
        if (overlay) overlay.style.opacity = '1';
      }, 350);

      // Flag the next page to fade the overlay OUT on load
      setTimeout(() => {
        sessionStorage.setItem('rocket-transition', '1');
        window.location.href = url;
      }, 700);
    }

    leftWing.addEventListener('click',  () => launch(softSkillsUrl, 'left'));
    rightWing.addEventListener('click', () => launch(skillsUrl, 'right'));

    leftWing.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); launch(softSkillsUrl, 'left'); }
    });
    rightWing.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); launch(skillsUrl, 'right'); }
    });
  }

  document.addEventListener('astro:page-load', initRocket);
  initRocket();
</script>
