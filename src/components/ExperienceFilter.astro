---
import SearchBadge from "./ui/SearchBadge.astro";
import FilterBadge from "./ui/FilterBadge.astro";
import type { Locale } from "../i18n/config";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div
  class="filter-toolbar mb-8 pt-4"
  role="toolbar"
  aria-label={locale === "en" ? "Filter timeline" : "Filtrer le parcours"}
>
  <FilterBadge class="focus-ring exp-filter" active data-filter="all"
    >{locale === "en" ? "All" : "Tout"}</FilterBadge
  >
  <FilterBadge class="focus-ring exp-filter" data-filter="pro"
    >{locale === "en" ? "Work" : "Pro"}</FilterBadge
  >
  <FilterBadge class="focus-ring exp-filter" data-filter="formation"
    >{locale === "en" ? "Studies" : "Etudes"}</FilterBadge
  >
  <SearchBadge locale={locale} />
</div>
