---
import SearchBadge from "./ui/SearchBadge.astro";
---
<div class="mb-8 pt-4 flex flex-wrap items-center gap-3" role="toolbar" aria-label="Filtrer le parcours">
  <button class="focus-ring exp-filter rounded-full border border-cosmic-gold/40 px-4 py-2 text-xs uppercase tracking-[0.2em] transition-all" data-filter="all">Tout</button>
  <button class="focus-ring exp-filter rounded-full border border-cosmic-gold/20 px-4 py-2 text-xs uppercase tracking-[0.2em] transition-all" data-filter="pro">Pro</button>
  <button class="focus-ring exp-filter rounded-full border border-cosmic-gold/20 px-4 py-2 text-xs uppercase tracking-[0.2em] transition-all" data-filter="formation">Etudes</button>
  <SearchBadge />
</div>
