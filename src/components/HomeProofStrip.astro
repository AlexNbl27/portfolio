---
import type { Locale } from "../i18n/config";
import TestimonialCard from "./TestimonialCard.astro";
import { getTestimonials } from "../data/testimonials";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const isEn = locale === "en";
const featured = getTestimonials(locale)[0];

const stats = isEn
  ? [
      { label: "Years coding", value: "4+" },
      { label: "Projects delivered", value: "12+" },
      { label: "Domains", value: "Web · Mobile · IoT · Industry" },
    ]
  : [
      { label: "Années de code", value: "4+" },
      { label: "Projets livrés", value: "12+" },
      { label: "Domaines", value: "Web · Mobile · IoT · Industrie" },
    ];
---

<section class="grid gap-5 lg:grid-cols-[1.2fr_1fr]">
  <div class="rounded-card border border-white/10 bg-[#0f1430]/65 p-5 md:p-6 backdrop-blur-md">
    <p class="text-xs uppercase tracking-[0.22em] text-cosmic-pink">{isEn ? "Quick signals" : "Signaux rapides"}</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      {stats.map((s) => (
        <div class="rounded-xl border border-white/10 bg-white/5 p-3">
          <p class="text-xl font-semibold text-cosmic-gold">{s.value}</p>
          <p class="text-xs text-white/70 mt-1">{s.label}</p>
        </div>
      ))}
    </div>
    <div class="mt-4 flex flex-wrap gap-3 text-xs md:text-sm">
      <a href={isEn ? "/en/services" : "/services"} class="text-cosmic-gold hover:text-cosmic-pink transition">{isEn ? "See services" : "Voir les services"}</a>
      <a href={isEn ? "/en/contact" : "/contact"} class="text-cosmic-gold hover:text-cosmic-pink transition">{isEn ? "Book a call" : "Réserver un échange"}</a>
    </div>
  </div>

  <TestimonialCard {...featured} />
</section>
