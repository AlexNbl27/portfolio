---
import { Image } from "astro:assets";

import Badge from "./ui/Badge.astro";
import Button from "./ui/Button.astro";
import Card from "./ui/Card.astro";

import type { ProjectItem } from "../i18n/data/types";
import type { Locale } from "../i18n/config";

const { project, locale } = Astro.props as {
  project: ProjectItem;
  locale: Locale;
};

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif,webp,avif}",
  { eager: true },
);
const imagePath = `/src/assets${project.imageUrl}`;
const imageSrc = images[imagePath];
---

<Card
  as="article"
  interactive
  class="group flex flex-col h-full object-cover project-card mobile-card"
  data-category={project.category}
  data-detail-page={project.detailPage}
>
  <div
    class="relative w-full overflow-hidden shrink-0 aspect-video bg-slate-800/60"
  >
    {
      imageSrc ? (
        <Image
          src={imageSrc.default}
          alt={project.title}
          class="project-card-img h-full w-full object-cover transition duration-700 group-hover:scale-112 rounded-card"
          data-fade-image
          transition:name={`project-image-${project.title}`}
          decoding="async"
          loading="lazy"
        />
      ) : (
        <div class="h-full w-full object-cover bg-slate-800" />
      )
    }
  </div>

  <div class="flex flex-col flex-grow p-3.5 md:p-5">
    <div class="space-y-2.5 md:space-y-3 flex-grow z-10">
      <div class="flex items-center justify-between gap-2">
        <div>
          <p class="ui-kicker text-cosmic-pink">
            {project.category}
          </p>
          {
            project.company && (
              <p class="ui-meta text-white/70 mt-0.5">
                {project.company}
              </p>
            )
          }
        </div>
        {
          project.inProduction && (
            <span class="flex items-center gap-1.5 text-[10px] font-medium uppercase tracking-widest text-cosmic-gold shrink-0">
              <span class="h-1.5 w-1.5 rounded-full bg-cosmic-gold animate-pulse" />
              {locale === "en" ? "Live" : "En prod"}
            </span>
          )
        }
      </div>
      <h3 class="font-display text-[1.16rem] leading-tight text-cosmic-gold md:text-3xl">
        {project.title}
      </h3>
      <p class="muted ui-body-sm line-clamp-3 md:line-clamp-3">{project.description}</p>

      <div class="flex flex-wrap gap-2 text-xs">
        {
          project.technologies.map((tech, index) => (
            <Badge variant="tech" class:list={[index > 2 && "hidden md:inline-flex"]}>
              {tech}
            </Badge>
          ))
        }
      </div>
    </div>

    <div class="flex flex-wrap gap-2 pt-2 mt-auto z-10 relative md:gap-3 md:pt-4">
      {
        project.detailPage && (
          <Button
            href={project.detailPage}
            variant="primary"
            aria-label={`${locale === "en" ? "Learn more about" : "En savoir plus sur"} ${project.title}`}
          >
            {locale === "en" ? "Learn more" : "En savoir +"}
          </Button>
        )
      }
      {
        project.demoUrl && (
          <Button
            href={project.demoUrl}
            target="_blank"
            rel="noreferrer"
            variant="outline"
            icon="lucide:external-link"
            aria-label={`${locale === "en" ? "Visit site for" : "Voir le site du projet"} ${project.title}`}
          >
            {project.inProduction
              ? locale === "en"
                ? "Visit site"
                : "Voir le site"
              : locale === "en"
                ? "Demo"
                : "Démo"}
          </Button>
        )
      }
      {
        project.githubUrl && (
          <Button
            href={project.githubUrl}
            target="_blank"
            rel="noreferrer"
            variant="outline"
            icon="lucide:github"
            class="hidden md:inline-flex"
            aria-label={`${locale === "en" ? "Source code for" : "Code source du projet"} ${project.title}`}
          >
            GitHub
          </Button>
        )
      }
    </div>
  </div>
</Card>
