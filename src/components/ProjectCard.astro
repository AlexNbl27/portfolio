---
import { Image } from "astro:assets";

import Badge from "./ui/Badge.astro";
import Button from "./ui/Button.astro";
import Card from "./ui/Card.astro";

import type { ProjectItem } from "../i18n/data/types";
import type { Locale } from "../i18n/config";

const { project, locale } = Astro.props as { project: ProjectItem; locale: Locale };

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif,webp,avif}",
  { eager: true }
);
const imagePath = `/src/assets${project.imageUrl}`;
const imageSrc = images[imagePath];
---

<Card
  as="article"
  interactive
  class="group flex flex-col h-full object-cover project-card"
  data-category={project.category}
  data-detail-page={project.detailPage}
>
  <div class="relative w-full overflow-hidden shrink-0 aspect-video bg-slate-800/60">
    {
      imageSrc ? (
        <Image
          src={imageSrc.default}
          alt={project.title}
          class="project-card-img h-full w-full object-cover transition duration-700 group-hover:scale-115 rounded-card"
          data-fade-image
          transition:name={`project-image-${project.title}`}
          decoding="async"
          loading="lazy"
        />
      ) : (
        <div class="h-full w-full object-cover bg-slate-800" />
      )
    }
  </div>

  <div class="flex flex-col flex-grow p-5">
    <div class="space-y-3 flex-grow z-10">
      <p class="text-xs uppercase tracking-[0.25em] text-cosmic-pink">
        {project.category}
      </p>
      <h3 class="font-display text-3xl text-cosmic-gold">
        {project.title}
      </h3>
      <p class="muted line-clamp-3">{project.description}</p>

      <div class="flex flex-wrap gap-2 text-xs">
        {
          project.technologies.map((tech) => (
            <Badge variant="tech">{tech}</Badge>
          ))
        }
      </div>
    </div>

    <div class="flex flex-wrap gap-3 pt-4 mt-auto z-10 relative">
      {
        project.detailPage && (
          <Button
            href={project.detailPage}
            variant="primary"
            aria-label={`${locale === "en" ? "Learn more about" : "En savoir plus sur"} ${project.title}`}
          >
            {locale === "en" ? "Learn more" : "En savoir plus"}
          </Button>
        )
      }
      {
        project.demoUrl && (
          <Button
            href={project.demoUrl}
            target="_blank"
            rel="noreferrer"
            variant="outline"
            icon="lucide:external-link"
            aria-label={`${locale === "en" ? "Live demo for" : "Démo live du projet"} ${project.title}`}
          >
            {locale === "en" ? "Demo" : "Démo"}
          </Button>
        )
      }
      {
        project.githubUrl && (
          <Button
            href={project.githubUrl}
            target="_blank"
            rel="noreferrer"
            variant="outline"
            icon="lucide:github"
            aria-label={`${locale === "en" ? "Source code for" : "Code source du projet"} ${project.title}`}
          >
            GitHub
          </Button>
        )
      }
    </div>
  </div>
</Card>
