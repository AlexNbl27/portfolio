---
import type { Locale } from "../i18n/config";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isEn = locale === "en";
---

<section
  class="astral-chat astral-chat--booting flex w-full relative"
  data-astral-chat-root
  data-mode="page"
>
  <div class="astral-chat__panel is-page flex">
    <div class="astral-chat__messages-header">
      <div class="flex items-stretch gap-1 bg-white/5 p-1 rounded-lg border border-white/10 w-fit">
        <label class="cursor-pointer relative flex-1">
          <input type="radio" name="astral_mode_page" value="astro" data-astral-personality class="peer sr-only" checked>
          <div class="flex h-full flex-col items-center justify-center px-3 py-2 rounded-md peer-checked:bg-blue-500/30 peer-checked:text-blue-200 text-white/50 transition-colors hover:bg-white/5 hover:text-white/80">
            <span class="block text-[0.75rem] font-bold leading-none">Astro</span>
            <span class="block text-[0.55rem] font-medium opacity-70 mt-1 uppercase tracking-wider">{isEn ? "Recruiter" : "Pro"}</span>
          </div>
        </label>
        <label class="cursor-pointer relative flex-1">
          <input type="radio" name="astral_mode_page" value="sirius" data-astral-personality class="peer sr-only">
          <div class="flex h-full flex-col items-center justify-center px-3 py-2 rounded-md peer-checked:bg-emerald-500/30 peer-checked:text-emerald-200 text-white/50 transition-colors hover:bg-white/5 hover:text-white/80">
            <span class="block text-[0.75rem] font-bold leading-none">Sirius</span>
            <span class="block text-[0.55rem] font-medium opacity-70 mt-1 uppercase tracking-wider">{isEn ? "Client" : "Client"}</span>
          </div>
        </label>
        <label class="cursor-pointer relative flex-1">
          <input type="radio" name="astral_mode_page" value="saturn" data-astral-personality class="peer sr-only">
          <div class="flex h-full flex-col items-center justify-center px-3 py-2 rounded-md peer-checked:bg-orange-500/30 peer-checked:text-orange-200 text-white/50 transition-colors hover:bg-white/5 hover:text-white/80">
            <span class="block text-[0.75rem] font-bold leading-none">Saturn</span>
            <span class="block text-[0.55rem] font-medium opacity-70 mt-1 uppercase tracking-wider">{isEn ? "Friendly" : "Ami"}</span>
          </div>
        </label>
        <label class="cursor-pointer relative flex-1">
          <input type="radio" name="astral_mode_page" value="nova" data-astral-personality class="peer sr-only">
          <div class="flex h-full flex-col items-center justify-center px-3 py-2 rounded-md peer-checked:bg-purple-500/30 peer-checked:text-purple-200 text-white/50 transition-colors hover:bg-white/5 hover:text-white/80">
            <span class="block text-[0.75rem] font-bold leading-none">Nova</span>
            <span class="block text-[0.55rem] font-medium opacity-70 mt-1 uppercase tracking-wider">{isEn ? "Creative" : "Créatif"}</span>
          </div>
        </label>
      </div>
      <button
        type="button"
        class="astral-chat__clear focus-ring"
        aria-label={isEn ? "New conversation" : "Nouvelle conversation"}
        title={isEn ? "New conversation" : "Nouvelle conversation"}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
        {isEn ? "New conversation" : "Nouvelle conversation"}
      </button>
    </div>
    <div class="astral-chat__messages" aria-live="polite"></div>

    <form class="astral-chat__composer">
      <label class="sr-only" for="astral-chat-input-page">{isEn ? "Your message" : "Votre message"}</label>
      <textarea
        id="astral-chat-input-page"
        placeholder={isEn ? "Write your message…" : "Écrivez votre message…"}
        rows="1"
        maxlength="800"
        required></textarea>
      <button type="submit" class="focus-ring">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
      </button>
    </form>
  </div>
</section>

<script>
  import "../scripts/astral-chat";
</script>

<style is:global>
  @import "../styles/astral-chat.css";

  .astral-chat__panel.is-page {
    width: 100%;
    max-width: 100%;
    margin-inline: auto;
    max-height: none;
    min-height: unset;
    padding-inline: 0;
    flex-direction: column;
    gap: 1.2rem;
    opacity: 1;
    transform: none;
    pointer-events: auto;
    border: 1px solid rgba(246, 212, 13, 0.12);
    border-radius: 1.2rem;
    padding: 1.5rem;
    background: rgba(15, 20, 45, 0.45);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .astral-chat__messages-header { display: flex; justify-content: space-between; gap: 1rem; align-items: center; flex-wrap: wrap; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 1rem; margin-bottom: 0.5rem; }
  .astral-chat__panel.is-page .astral-chat__clear { display: inline-flex; align-items: center; gap: 0.35rem; border: 0; background: transparent; color: rgba(180, 184, 202, 0.55); font-size: 0.75rem; cursor: pointer; padding: 0.25rem 0.5rem; border-radius: 6px; transition: color 0.2s, background 0.2s; }
  .astral-chat__panel.is-page .astral-chat__clear:hover { color: #f6d40d; background: rgba(246, 212, 13, 0.06); }
  .astral-chat__panel.is-page .astral-chat__messages { overflow-y: visible; padding-bottom: 1rem; }
  .astral-chat__panel.is-page .astral-chat__composer { position: sticky; bottom: 1.5rem; background: rgba(8, 12, 26, 0.85); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); border-radius: 1.2rem; padding: 0.75rem; border: 1px solid rgba(246, 212, 13, 0.2); z-index: 10; }
</style>
