---
import ExperienceCard from "./ExperienceCard.astro";
import type { ExperienceItem } from "../i18n/data/types";
import type { Locale } from "../i18n/config";

const { experiences, locale } = Astro.props as { experiences: ExperienceItem[]; locale: Locale };
---

<section class="mt-0" id="experience-timeline">
  <div
    class="experience-timeline-track experience-timeline-stack relative before:absolute before:top-0 before:h-full before:w-[1px]"
  >
    {
      experiences.map((item, idx: number) => (
        <div
          class:list={[
            "experience-item grid items-start md:grid-cols-2 md:gap-10",
            idx % 2 === 0
              ? "experience-item--left"
              : "experience-item--right md:[&>*:first-child]:order-2",
          ]}
          data-period={item.period}
          data-type={item.type ?? "pro"}
          data-recruiter-visible={item.recruiterVisible ? "true" : "false"}
          data-role={item.role}
          data-company={item.company}
          data-description={item.description}
        >
          <div class="experience-node relative py-4 pl-10 pr-0 md:p-0">
            <ExperienceCard item={item} locale={locale} />
          </div>
          <div class="hidden md:block" />
        </div>
      ))
    }
  </div>
</section>
