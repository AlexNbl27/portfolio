---

---

<div class="astral-age-container group hidden lg:block" id="scroll-age">
  <!-- Astral Rings (Mirrors the Portrait's design) -->
  <div class="astral-frame-rings" aria-hidden="true">
    <div class="ring-outer"></div>
    <div class="ring-middle"></div>
    <div
      class="ring-inner flex items-center justify-center bg-slate-900/60 backdrop-blur-md"
    >
      <div class="orbiting-dot"></div>

      <!-- Central Age Number -->
      <div class="age-display text-center relative z-20">
        <span
          id="age-num"
          class="text-6xl font-mono font-bold text-cosmic-gold drop-shadow-[0_0_15px_rgba(246,212,13,0.5)]"
          >23</span
        >
        <div class="text-[10px] uppercase tracking-[0.3em] opacity-40 mt-1">
          Ans
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function initTemporalCompass() {
    const container = document.getElementById("scroll-age");
    const ageNum = document.getElementById("age-num");
    const timelineItems = document.querySelectorAll(".experience-item");

    if (!container || !ageNum || timelineItems.length === 0) return;
    const currentYear = new Date().getFullYear();

    const events = Array.from(timelineItems).map((el) => {
      const period = el.getAttribute("data-period") || "";
      const yearMatch = period.match(/\d{4}/);
      return {
        element: el,
        year: yearMatch ? parseInt(yearMatch[0]) : currentYear,
      };
    });

    let ticking = false;

    function handleScroll() {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateCompass();
          ticking = false;
        });
        ticking = true;
      }
    }

    function updateCompass() {
      if (window.innerWidth < 1024) return;

      const viewportCenter = window.innerHeight * 0.5;
      let activeYear = currentYear;

      // Handle "Present" before the first event
      const firstItem = events[0].element.getBoundingClientRect();
      if (firstItem.top > viewportCenter) {
        const blend = Math.min(
          1,
          Math.max(0, (viewportCenter - (firstItem.top - 200)) / 200),
        );
        activeYear =
          currentYear - Math.floor(blend * (currentYear - events[0].year));
      } else {
        // Find current pair of items we are between
        for (let i = 0; i < events.length; i++) {
          const rect = events[i].element.getBoundingClientRect();
          const nextRect = events[i + 1]?.element.getBoundingClientRect();

          if (
            rect.top <= viewportCenter &&
            (!nextRect || nextRect.top > viewportCenter)
          ) {
            activeYear = events[i].year;

            if (nextRect) {
              const gap = nextRect.top - rect.top;
              const progressInGap = (viewportCenter - rect.top) / gap;
              activeYear = Math.floor(
                events[i].year -
                  progressInGap * (events[i].year - events[i + 1].year),
              );
            }
            break;
          }
        }
      }

      // Final polish for absolute top/bottom
      const scrollY = window.scrollY;
      const scrollMax = document.documentElement.scrollHeight;
      if (scrollY < 50) activeYear = currentYear;
      if (window.innerHeight + scrollY > scrollMax - 80)
        activeYear = events[events.length - 1].year;

      // Update Age: EventYear - 2003
      const age = Math.max(0, activeYear - 2003);
      if (ageNum) ageNum.textContent = age.toString();
    }

    window.addEventListener("scroll", handleScroll, { passive: true });
    window.addEventListener("resize", handleScroll);
    handleScroll();
  }

  document.addEventListener("astro:page-load", initTemporalCompass);
</script>

<style>
  .astral-age-container {
    position: fixed;
    right: max(calc(2rem + 40px), calc(50vw - 550px - 285px + 40px));
    top: 36rem;
    width: 180px;
    height: 180px;
    z-index: 40;
    pointer-events: none;
  }

  /* Astral Rings (Copied/Adapted from Portrait) */
  .astral-frame-rings {
    position: absolute;
    inset: -30px;
    pointer-events: none;
  }

  .ring-outer {
    position: absolute;
    inset: 0;
    border: 1px dashed rgba(246, 212, 13, 0.2);
    border-radius: 50%;
    animation: rotate 60s linear infinite;
  }

  .ring-middle {
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 50%;
    animation: rotate 45s linear infinite reverse;
    will-change: transform;
  }

  .ring-inner {
    position: absolute;
    inset: 28px;
    border: 2px solid rgba(246, 212, 13, 0.3);
    border-radius: 50%;
    box-shadow: 0 0 20px rgba(246, 212, 13, 0.1);
    z-index: 5;
    transition: all 0.5s ease;
    overflow: hidden;
  }

  .orbiting-dot {
    position: absolute;
    top: -3px;
    left: 50%;
    width: 6px;
    height: 6px;
    background: #f6d40d;
    border-radius: 50%;
    box-shadow: 0 0 15px #f6d40d;
    transform: translateX(-50%);
    animation: orbit 15s linear infinite;
    transform-origin: center 120px;
  }

  @keyframes rotate {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes orbit {
    from {
      transform: translateX(-50%) rotate(0deg);
    }
    to {
      transform: translateX(-50%) rotate(360deg);
    }
  }

  /* Fade out on medium screens like the portrait */
  @media (max-width: 1600px) {
    .astral-age-container {
      opacity: 0.2;
      filter: grayscale(0.5) blur(1px);
    }
  }
</style>
