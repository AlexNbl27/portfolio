---
import Card from "./ui/Card.astro";
import type { ServicePack } from "../data/services";

interface Props {
  pack: ServicePack;
}

const { pack } = Astro.props as Props;
---

<Card as="article" hoverable shine class="service-pack-card mobile-card p-4 md:p-5">
  <p class="text-xs uppercase tracking-[0.18em] text-cosmic-pink">
    {pack.priceHint}
  </p>
  <h3 class="mt-2 text-cosmic-gold text-[1.65rem] leading-tight font-display md:text-2xl">{pack.name}</h3>
  <p class="mt-2 text-sm text-white/75">{pack.subtitle}</p>

  <ul
    class="service-pack-card__list mt-4 space-y-2 text-sm text-white/80 list-disc pl-5"
  >
    {pack.deliverables.map((item) => <li>{item}</li>)}
  </ul>

  <p class="mt-4 text-xs text-white/65">{pack.idealFor}</p>
</Card>
