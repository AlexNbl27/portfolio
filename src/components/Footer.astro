---
import type { Locale } from "../i18n/config";
import { DEFAULT_LOCALE, COOKIE_NAME } from "../i18n/config";
import { useTranslations } from "../i18n/useTranslations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<footer class="relative z-10 pb-10 pt-7 text-center text-[10px] uppercase tracking-[0.14em] text-slate-500 md:text-xs md:tracking-[0.18em]">
  <div class="cosmic-container">
    <div class="mb-3 flex flex-wrap justify-center gap-4">
      <a href="https://www.linkedin.com/in/alexnbl27" target="_blank" rel="noreferrer" class="focus-ring hover:text-cosmic-gold">LinkedIn</a>
      <a href="https://github.com/AlexNbl27" target="_blank" rel="noreferrer" class="focus-ring hover:text-cosmic-gold">GitHub</a>
      <a href="/docs/CV-NOBLET.pdf" target="_blank" rel="noreferrer" class="focus-ring hover:text-cosmic-gold">CV</a>
      <a href="mailto:alexandrenobletpro@gmail.com" class="focus-ring hover:text-cosmic-gold">Email</a>
    </div>

    <div class="mb-4 flex items-center justify-center gap-2">
      <span class="text-[10px] opacity-80">{t("footer").localeLabel}</span>
      <div class="inline-flex rounded-full border border-cosmic-gold/20 bg-slate-900/70 p-1 shadow-[0_0_20px_rgba(246,212,13,0.08)]">
        <button type="button" class:list={["focus-ring rounded-full px-3 py-1 text-[10px] tracking-[0.15em] transition", locale === "fr" ? "bg-cosmic-gold text-slate-900" : "text-slate-300 hover:text-cosmic-gold"]} data-locale-switch="fr">FR</button>
        <button type="button" class:list={["focus-ring rounded-full px-3 py-1 text-[10px] tracking-[0.15em] transition", locale === "en" ? "bg-cosmic-gold text-slate-900" : "text-slate-300 hover:text-cosmic-gold"]} data-locale-switch="en">EN</button>
      </div>
    </div>

    <p class="text-[10px] tracking-[0.1em] text-slate-500/90 md:text-[11px]">{t("footer").copyright}</p>
  </div>
</footer>

<script define:vars={{ COOKIE_NAME, DEFAULT_LOCALE }} is:inline>
  const stripLocalePrefix = (pathname) => {
    const clean = pathname.replace(/\/$/, "") || "/";
    return clean.replace(/^\/(fr|en)(?=\/|$)/, "") || "/";
  };

  const bindLocaleSwitcher = () => {
    document.querySelectorAll("[data-locale-switch]").forEach((button) => {
      if (button.dataset.boundLocale === "true") return;
      button.dataset.boundLocale = "true";
      button.addEventListener("click", () => {
        const targetLocale = button.getAttribute("data-locale-switch");
        if (!targetLocale) return;

        const basePath = stripLocalePrefix(window.location.pathname);
        const nextPath = targetLocale === DEFAULT_LOCALE
          ? basePath
          : `/${targetLocale}${basePath === "/" ? "" : basePath}`;

        localStorage.setItem("preferredLocale", targetLocale);
        document.cookie = `${COOKIE_NAME}=${targetLocale};path=/;max-age=31536000;SameSite=Lax`;
        window.location.assign(nextPath);
      });
    });
  };

  bindLocaleSwitcher();
  document.addEventListener("astro:page-load", bindLocaleSwitcher);
</script>
