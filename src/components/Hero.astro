---
import Button from './ui/Button.astro';
---
<section class="cosmic-container pt-8">
  <p class="mb-4 text-sm uppercase tracking-[0.3em] text-cosmic-pink">
    Portfolio • Développement & IoT
  </p>
  <h1 class="section-title mb-6 max-w-4xl">Alexandre <span class="highlight">Noblet</span></h1>
  <p class="muted max-w-3xl text-base md:text-lg">
    Je conçois des expériences web et IoT utiles, lisibles et orientées
    produit. Mon objectif : transformer une idée en solution concrète,
    performante et agréable à utiliser.
  </p>
  <div
    class="mt-6 grid gap-3 rounded-2xl border border-cosmic-gold/15 bg-slate-900/20 p-4 text-sm text-cosmic-gold/80 sm:grid-cols-3"
  >
    <p class="rounded-xl border border-cosmic-gold/10 px-3 py-2">
      🧭 Vision produit claire
    </p>
    <p class="rounded-xl border border-cosmic-gold/10 px-3 py-2">
      ⚙️ Base technique solide
    </p>
    <p class="rounded-xl border border-cosmic-gold/10 px-3 py-2">
      📱 Mobile-first & responsive
    </p>
  </div>
  <div class="mt-6 flex flex-wrap gap-3">
    <Button href="/projects" variant="primary">Voir mes projets</Button>
    <Button href="/experience" variant="outline">Parcours 60 sec</Button>
    <Button href="mailto:alexandrenobletpro@gmail.com" variant="outline">Me contacter</Button>
  </div>
</section>
