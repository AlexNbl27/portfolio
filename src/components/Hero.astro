---
import type { Locale } from '../i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isEn = locale === 'en';
---
<section class="cosmic-container page-hero">
  <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-cosmic-pink md:text-sm md:tracking-[0.3em]">
    {isEn ? 'Portfolio • Development & IoT' : 'Portfolio • Développement & IoT'}
  </p>
  <h1 class="section-title page-hero__title mt-0 mb-6 max-w-4xl tracking-tight">Alexandre <span class="highlight">Noblet</span></h1>
  <p class="muted page-hero__desc">
    {isEn
      ? 'I design useful, readable, product-oriented web and IoT experiences. My goal: turn ideas into concrete, high-performing, delightful solutions.'
      : 'Je conçois des expériences web et IoT utiles, lisibles et orientées produit. Mon objectif : transformer une idée en solution concrète, performante et agréable à utiliser.'}
  </p>
</section>
