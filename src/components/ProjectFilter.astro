---
import FilterBadge from "./ui/FilterBadge.astro";
import type { Locale } from "../i18n/config";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const categories =
  locale === "en"
    ? [
        { value: "all", label: "All" },
        { value: "saas", label: "SaaS" },
        { value: "web", label: "Web" },
        { value: "mobile", label: "Mobile" },
        { value: "desktop", label: "Desktop" },
        { value: "integration", label: "Integration" },
      ]
    : [
        { value: "all", label: "Tous" },
        { value: "saas", label: "SaaS" },
        { value: "web", label: "Web" },
        { value: "mobile", label: "Mobile" },
        { value: "desktop", label: "Desktop" },
        { value: "integration", label: "Intégration" },
      ];
---

<div
  class="filter-toolbar mb-8 pt-4"
  role="toolbar"
  aria-label={locale === "en" ? "Filter projects" : "Filtrer les projets"}
>
  {
    categories.map((category) => (
      <FilterBadge
        class="focus-ring filter-btn"
        active={category.value === "all"}
        data-category={category.value}
      >
        {category.label}
      </FilterBadge>
    ))
  }
</div>
