---
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillVisualization from "../components/SkillVisualization.astro";
import data from "../data/soft-skills.json";
---

<BaseLayout title={data.page.title} description={data.page.description}>
  <section class="cosmic-container pt-8 pb-16">
    <div class="mb-6 text-left">
      <h1 class="section-title mb-2">
        Mes <span class="highlight">soft skills</span>
      </h1>
      <p class="muted max-w-3xl text-lg leading-relaxed">{data.page.intro}</p>
    </div>
    <SkillVisualization />
  </section>
</BaseLayout>
