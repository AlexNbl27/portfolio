---
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillVisualization from "../components/SkillVisualization.astro";
import { getLocaleFromPathname } from "../i18n/utils";
import { getSoftSkillsData } from "../i18n/data/soft-skills";

const locale = getLocaleFromPathname(Astro.url.pathname);
const data = getSoftSkillsData(locale);
---

<BaseLayout title={data.page.title} description={data.page.description}>
  <section class="cosmic-container pt-8 pb-4">
    <div class="mb-6 text-left">
      <h1 class="section-title mb-2">
        {locale === "en" ? "My" : "Mes"} <span class="highlight">soft skills</span>
      </h1>
      <p class="muted page-hero__desc">{data.page.intro}</p>
    </div>
  </section>
  <SkillVisualization locale={locale} />
  <div class="pb-16"></div>
</BaseLayout>
