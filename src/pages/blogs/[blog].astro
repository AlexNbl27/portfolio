---
import BaseLayout from "../../layouts/BaseLayout.astro";
import blogs, { type BlogMeta } from "../../data/blogs";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";
import Badge from "../../components/ui/Badge.astro";
import { Image } from "astro:assets";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif,webp,avif}",
  { eager: true },
);
const resolveImage = (path?: string) =>
  path && images[`/src/assets${path}`]
    ? images[`/src/assets${path}`].default
    : null;

export function getStaticPaths() {
  return blogs.map((blog) => ({
    params: { blog: blog.slug },
    props: { blog },
  }));
}

const { blog } = Astro.props as { blog: BlogMeta };
---

<BaseLayout
  title={`Alexandre Noblet | ${blog.title}`}
  description={blog.summary}
>
  <section class="cosmic-container pt-8">
    <Button href="/blogs" variant="outline" icon="lucide:arrow-left">
      Retour aux blogs
    </Button>

    <div class="mt-6 grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="space-y-5">
        <p class="text-xs uppercase tracking-[0.25em] text-cosmic-pink">
          {blog.subtitle}
        </p>
        <h1 class="section-title">{blog.title}</h1>
        <p class="muted text-lg">{blog.summary}</p>

        <div class="flex flex-wrap gap-2 text-xs">
          {blog.skills.map((skill) => <Badge variant="default">{skill}</Badge>)}
        </div>
      </div>

      {
        blog.coverImage && resolveImage(blog.coverImage) && (
          <Card class="overflow-hidden">
            <Image
              src={resolveImage(blog.coverImage)!}
              alt={blog.title}
              class="h-full w-full object-cover"
            />
          </Card>
        )
      }
    </div>

    <section class="mt-8">
      <h2 class="font-display text-4xl text-cosmic-gold">
        Toutes les publications
      </h2>
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        {
          blog.posts.map((post) => (
            <Card
              as="a"
              href={`/blogs/${blog.slug}/${post.slug}`}
              interactive
              class="group/card p-5 flex flex-col items-start relative z-10 hover:no-underline"
            >
              <time class="text-xs uppercase tracking-[0.2em] text-cosmic-pink">
                {post.date}
              </time>
              <h3 class="mt-2 font-display text-3xl transition-colors group-hover/card:text-cosmic-gold">
                {post.title}
              </h3>
              <p class="muted mt-2 mb-4">{post.excerpt}</p>
              <Button
                as="span"
                variant="outline"
                class="mt-auto pointer-events-none group-hover/card:bg-cosmic-gold group-hover/card:text-black mt-auto"
              >
                Lire l’article
              </Button>
            </Card>
          ))
        }
      </div>
    </section>
  </section>
</BaseLayout>
