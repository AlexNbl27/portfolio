---
import BaseLayout from '../../layouts/BaseLayout.astro';
import blogs from '../../data/blogs';
---

<BaseLayout title="Alexandre Noblet | Blogs" description="Articles et retours d’expérience d’Alexandre Noblet.">
  <section class="cosmic-container pt-8">
    <h1 class="section-title">Mes <span class="highlight">blogs</span></h1>
    <p class="muted mt-4 max-w-3xl text-lg">J’y regroupe mes retours d’expérience, mes articles de stage et mes notes d’alternance. Chaque blog dispose maintenant de ses propres sous-pages.</p>

    <div class="mt-8 grid gap-4 xl:grid-cols-2">
      {blogs.map((blog) => {
        const recentPosts = [...blog.posts].slice(-2).reverse();

        return (
          <article class="glass-card h-full p-4 md:p-5">
            <div class="grid gap-4 md:grid-cols-[190px_1fr] md:items-start">
              {blog.coverImage && (
                <img src={blog.coverImage} alt={blog.title} class="h-40 w-full rounded-2xl object-cover md:h-full md:min-h-[190px]" />
              )}

              <div class="space-y-3">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="text-[11px] uppercase tracking-[0.25em] text-cosmic-pink">{blog.subtitle}</p>
                  <span class="rounded-full border border-cosmic-gold/20 px-2 py-1 text-[10px] uppercase tracking-[0.2em] text-slate-300">
                    {blog.posts.length} article{blog.posts.length > 1 ? 's' : ''}
                  </span>
                </div>

                <h2 class="font-display text-3xl text-cosmic-gold md:text-4xl">{blog.title}</h2>
                <p class="muted text-sm">{blog.summary}</p>

                <div class="flex flex-wrap gap-2 text-[11px]">
                  {blog.skills.slice(0, 4).map((skill) => <span class="rounded-full bg-slate-900/60 px-3 py-1">{skill}</span>)}
                </div>

                <div class="rounded-2xl border border-cosmic-gold/15 p-3">
                  <p class="mb-2 text-[11px] uppercase tracking-[0.2em] text-cosmic-pink">Derniers articles</p>
                  <ul class="space-y-1 text-sm">
                    {recentPosts.map((post) => (
                      <li>
                        <a href={`/blogs/${blog.slug}/${post.slug}`} class="focus-ring hover:text-cosmic-gold">• {post.title}</a>
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="flex flex-wrap gap-3 pt-1">
                  <a href={`/blogs/${blog.slug}`} class="focus-ring inline-block rounded-full bg-cosmic-gold px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-black">Ouvrir</a>
                  <a href={`/blogs/${blog.slug}/${blog.posts[blog.posts.length - 1].slug}`} class="focus-ring inline-block rounded-full border border-cosmic-gold/30 px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] hover:border-cosmic-gold">Dernier article</a>
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
