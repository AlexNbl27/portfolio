---
import BaseLayout from "../../layouts/BaseLayout.astro";
import blogs from "../../data/blogs";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";
import Badge from "../../components/ui/Badge.astro";
import { Image } from "astro:assets";
import { getLocaleFromPathname } from "../../i18n/utils";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif,webp,avif}",
  { eager: true },
);
const resolveImage = (path?: string) =>
  path && images[`/src/assets${path}`]
    ? images[`/src/assets${path}`].default
    : null;

const locale = getLocaleFromPathname(Astro.url.pathname);
const isEn = locale === "en";
---

<BaseLayout
  title={isEn ? "Alexandre Noblet | Blog" : "Alexandre Noblet | Blogs"}
  description={isEn ? "Articles and experience notes by Alexandre Noblet." : "Articles et retours d’expérience d’Alexandre Noblet."}
>
  <section class="cosmic-container pt-8">
    <h1 class="section-title">{isEn ? "My" : "Mes"} <span class="highlight">blogs</span></h1>
    <p class="muted mt-4 max-w-3xl text-lg">
      {isEn ? "Here I collect experience feedback, internship write-ups, and apprenticeship notes. Each blog has dedicated sub-pages." : "J’y regroupe mes retours d’expérience, mes articles de stage et mes notes d’alternance. Chaque blog dispose maintenant de ses propres sous-pages."}
    </p>

    <div class="mt-8 grid gap-4 xl:grid-cols-2">
      {
        blogs.map((blog) => {
          const recentPosts = [...blog.posts].slice(-2).reverse();

          return (
            <Card as="article" interactive shine class="h-full p-4 md:p-5">
              <div class="grid gap-4 md:grid-cols-[190px_1fr] md:items-start">
                {blog.coverImage && resolveImage(blog.coverImage) && (
                  <Image
                    src={resolveImage(blog.coverImage)!}
                    alt={blog.title}
                    class="project-card-img h-40 w-full rounded-2xl object-cover md:h-full md:min-h-[190px]"
                    data-fade-image
                  />
                )}

                <div class="space-y-3 z-10">
                  <div class="flex flex-wrap items-center gap-2">
                    <p class="text-[11px] uppercase tracking-[0.25em] text-cosmic-pink">
                      {blog.subtitle}
                    </p>
                    <Badge variant="outline" class="text-[10px] text-slate-300">
                      {blog.posts.length} {isEn ? `article${blog.posts.length > 1 ? "s" : ""}` : `article${blog.posts.length > 1 ? "s" : ""}`}
                    </Badge>
                  </div>

                  <h2 class="font-display text-3xl text-cosmic-gold md:text-4xl">
                    {blog.title}
                  </h2>
                  <p class="muted text-sm">{blog.summary}</p>

                  <div class="flex flex-wrap gap-2 text-[11px]">
                    {blog.skills.slice(0, 4).map((skill) => (
                      <Badge variant="default">{skill}</Badge>
                    ))}
                  </div>

                  <div class="rounded-2xl border border-cosmic-gold/15 p-3">
                    <p class="mb-2 text-[11px] uppercase tracking-[0.2em] text-cosmic-pink">
                      {isEn ? "Latest posts" : "Derniers articles"}
                    </p>
                    <ul class="space-y-1 text-sm">
                      {recentPosts.map((post) => (
                        <li>
                          <a
                            href={`/blogs/${blog.slug}/${post.slug}`}
                            class="focus-ring hover:text-cosmic-gold"
                          >
                            • {post.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="flex flex-wrap gap-3 pt-1 relative z-10">
                    <Button href={`/blogs/${blog.slug}`} variant="primary">
                      {isEn ? "Open" : "Ouvrir"}
                    </Button>
                    <Button
                      href={`/blogs/${blog.slug}/${blog.posts[blog.posts.length - 1].slug}`}
                      variant="outline"
                    >
                      {isEn ? "Latest post" : "Dernier article"}
                    </Button>
                  </div>
                </div>
              </div>
            </Card>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
