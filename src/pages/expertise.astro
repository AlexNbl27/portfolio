---
import BaseLayout from "../layouts/BaseLayout.astro";
import RocketSelector from "../components/RocketSelector.astro";
import Card from "../components/ui/Card.astro";
import { getLocaleFromPathname, localizePath } from "../i18n/utils";

const locale = getLocaleFromPathname(Astro.url.pathname);
const isEn = locale === "en";
---

<BaseLayout
  title={isEn ? "Expertise · Alexandre Noblet" : "Expertise · Alexandre Noblet"}
  description={isEn ? "A single entry point to technical and interpersonal expertise." : "Un point d'entrée unique vers l'expertise technique et humaine."}
>
  <!-- Desktop: fusée plein écran, sans distractions -->
  <section class="rocket-fullscreen hidden md:flex">
    <RocketSelector
      softSkillsUrl={localizePath('/soft-skills', locale)}
      skillsUrl={localizePath('/skills', locale)}
      isEn={isEn}
    />
  </section>

  <!-- Mobile: titre + cards + astral -->
  <div class="md:hidden">
    <section class="cosmic-container pt-8">
      <h1 class="section-title">{isEn ? "My" : "Mon"} <span class="highlight">Expertise</span></h1>
      <p class="muted mt-4 max-w-2xl text-lg">
        {isEn
          ? "T-minus zero. Two wings, one trajectory — which one do you board?"
          : "T-moins zéro. Deux ailes, une trajectoire — laquelle tu embarques ?"}
      </p>
    </section>

    <section class="cosmic-container mt-8 flex flex-col gap-4">
      <a href={localizePath('/soft-skills', locale)} class="mobile-skill-card mobile-skill-card--pink">
        <span class="msc-tag">{isEn ? "Human" : "Humain"}</span>
        <span class="msc-title">Soft Skills</span>
        <span class="msc-desc">{isEn ? "Communication, collaboration, autonomy." : "Communication, collaboration, autonomie."}</span>
        <span class="msc-arrow">→</span>
      </a>
      <a href={localizePath('/skills', locale)} class="mobile-skill-card mobile-skill-card--gold">
        <span class="msc-tag">{isEn ? "Technical" : "Technique"}</span>
        <span class="msc-title">{isEn ? "Technical Skills" : "Compétences techniques"}</span>
        <span class="msc-desc">{isEn ? "Frameworks, languages, infrastructure." : "Frameworks, langages, infrastructure."}</span>
        <span class="msc-arrow">→</span>
      </a>
    </section>

    <section class="cosmic-container mt-10 mb-4">
      <Card class="p-6">
        <h2 class="font-display text-2xl text-cosmic-gold">{isEn ? "Need a guided tour?" : "Besoin d'un parcours guidé ?"}</h2>
        <p class="mt-2 text-white/80">{isEn ? "Use Astral chat for a role-based summary." : "Utilisez Astral pour un résumé orienté rôle."}</p>
        <a href={localizePath('/chat', locale)} class="mt-4 inline-flex rounded-xl border border-cosmic-gold/40 px-4 py-2 text-cosmic-gold hover:bg-cosmic-gold/10 transition">{isEn ? "Open Astral" : "Ouvrir Astral"}</a>
      </Card>
    </section>
  </div>
</BaseLayout>

<style>
  /* Desktop: fusée centrée, compense le padding du main */
  .rocket-fullscreen {
    width: 100%;
    min-height: calc(100vh - 5rem);
    margin-top: -4rem; /* remonte pour coller sous la navbar */
    align-items: center;
    justify-content: center;
    padding: 0 2rem;
  }

  /* Mobile cards */
  .mobile-skill-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 22px 20px;
    border-radius: 1.2rem;
    background: rgba(9, 15, 36, 0.7);
    backdrop-filter: blur(16px);
    border: 1px solid transparent;
    text-decoration: none;
    transition: border-color 0.3s, background 0.3s;
    position: relative;
  }
  .mobile-skill-card--pink { border-color: rgba(242, 180, 223, 0.25); }
  .mobile-skill-card--gold  { border-color: rgba(246, 212, 13, 0.25); }
  .mobile-skill-card--pink:hover { border-color: rgba(242, 180, 223, 0.6); background: rgba(242,180,223,0.05); }
  .mobile-skill-card--gold:hover  { border-color: rgba(246, 212, 13, 0.6);  background: rgba(246,212,13,0.05); }

  .msc-tag { font-size: 10px; letter-spacing: 4px; text-transform: uppercase; opacity: 0.65; }
  .msc-title { font-family: var(--font-display, 'Cormorant Garamond', serif); font-size: 30px; font-weight: 600; line-height: 1.1; }
  .msc-desc  { font-size: 14px; opacity: 0.65; }
  .msc-arrow {
    position: absolute; right: 20px; top: 50%; transform: translateY(-50%);
    font-size: 20px; opacity: 0.4; transition: opacity 0.3s, right 0.3s;
  }
  .mobile-skill-card:hover .msc-arrow { opacity: 0.9; right: 14px; }

  .mobile-skill-card--pink .msc-tag,
  .mobile-skill-card--pink .msc-title,
  .mobile-skill-card--pink .msc-arrow { color: #f2b4df; }
  .mobile-skill-card--gold .msc-tag,
  .mobile-skill-card--gold .msc-title,
  .mobile-skill-card--gold .msc-arrow { color: #f6d40d; }
  .mobile-skill-card--pink .msc-desc,
  .mobile-skill-card--gold .msc-desc  { color: rgba(255,255,255,0.65); }
</style>
