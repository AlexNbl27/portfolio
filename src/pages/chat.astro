---
import BaseLayout from "../layouts/BaseLayout.astro";
import AstralChatContent from "../components/AstralChatContent.astro";
import { getLocaleFromPathname } from "../i18n/utils";

const locale = getLocaleFromPathname(Astro.url.pathname);
const isEn = locale === "en";
---

<BaseLayout
  title={isEn ? "Astral Chat · Alexandre Noblet" : "Chat Astral · Alexandre Noblet"}
  description={isEn ? "Talk with Astral, the AI assistant in Alexandre Noblet's portfolio." : "Discutez avec Astral, l'assistant IA du portfolio d'Alexandre Noblet."}
>
  <section class="cosmic-container pt-8">
    <h1 class="section-title">{isEn ? "Astral" : "Canal"} <span class="highlight">Astral</span></h1>
    <p class="muted page-hero__desc mt-4">
      {isEn
        ? "An AI-powered conversational interface to explore my profile, projects, and technical approach in an interactive way."
        : "Une interface conversationnelle alimentée par l'IA pour explorer mon profil, mes projets et mon approche technique de manière interactive et immersive."}
    </p>

    <div class="mt-5 md:mt-8">
      <AstralChatContent locale={locale} />
    </div>
  </section>
</BaseLayout>
