---
import BaseLayout from '../layouts/BaseLayout.astro';
import MagicPortal from '../components/MagicPortal.astro';
import AIShowcase from '../components/AIShowcase.astro';
import ParticleEffect from '../components/ParticleEffect.astro';
---

<BaseLayout title="Magical Odyssey | AI Portal">
  <ParticleEffect />
  <section class="cosmic-container pt-8 text-center">
    <h1 class="section-title">The Magic <span class="highlight">Gateway</span></h1>
    <p class="muted mx-auto mt-4 max-w-3xl">Enter the threshold where intelligent systems amplify imagination and transform workflows into cosmic rituals.</p>
  </section>
  <MagicPortal />
  <AIShowcase />
</BaseLayout>
