---
import BaseLayout from '../layouts/BaseLayout.astro';
import MagicPortal from '../components/MagicPortal.astro';
import AIShowcase from '../components/AIShowcase.astro';
import ParticleEffect from '../components/ParticleEffect.astro';
---

<BaseLayout title="Alexandre Noblet | Blogs" description="Retours d’expérience d’Alexandre Noblet chez Orange Business Services.">
  <ParticleEffect />
  <section class="cosmic-container pt-8 text-center">
    <h1 class="section-title">Mes <span class="highlight">blogs</span></h1>
    <p class="muted mx-auto mt-4 max-w-3xl">Quelques retours d’expérience issus de mon stage puis de mon alternance chez Orange Business Services, autour du développement mobile, du fullstack et de l’IoT.</p>
  </section>
  <MagicPortal />
  <AIShowcase />
</BaseLayout>
