---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/ui/Card.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillOrbit from "../components/SkillOrbit.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import skills from "../data/skills.json";
import { getLocaleFromPathname, localizePath } from "../i18n/utils";
import { getProjects } from "../i18n/data/projects";
import { getExperiences } from "../i18n/data/experiences";

const locale = getLocaleFromPathname(Astro.url.pathname);
const isEn = locale === "en";

const projects = getProjects(locale);
const experiences = getExperiences(locale);

const featuredProjects = projects.filter((p) => p.recruiterFeatured);
const featuredSkills = skills.filter((s) => s.recruiterCore);
const featuredExperience = experiences.filter((e) => e.recruiterVisible);

const categoryLabelsEn: Record<string, string> = {
  "Mobile & logiciel": "Mobile & software",
  "Développement web": "Web development",
  "Backend & frameworks": "Backend & frameworks",
  "Base de données": "Databases",
  "DevOps & outils": "DevOps & tools",
  "Automatisme & industrie": "Automation & industry",
  "AI & Agentic Coding": "AI & Agentic coding",
};

const skillNarratives = Object.fromEntries(
  featuredSkills.map((skill) => {
    const match = (tech: string) =>
      tech.toLowerCase().includes(skill.name.toLowerCase()) ||
      skill.name.toLowerCase().includes(tech.toLowerCase());

    return [
      skill.name,
      {
        category: isEn ? (categoryLabelsEn[skill.category] ?? skill.category) : skill.category,
        proficiency: skill.proficiency,
        years: skill.yearsOfExperience ?? 0,
        projects: featuredProjects
          .filter((p) => p.technologies.some(match))
          .map((p) => ({ title: p.title, detailPage: p.detailPage ? localizePath(p.detailPage, locale) : undefined })),
        experience: featuredExperience
          .filter((e) => (e.technologies ?? []).some(match))
          .map((e) => ({ role: e.role, company: e.company })),
      },
    ];
  }),
);

const t = {
  title: isEn ? "Alexandre Noblet | Recruiter 60-second flow" : "Alexandre Noblet | Parcours recruteur 60 secondes",
  description: isEn
    ? "Recruiter one-page flow: featured projects, core skills and professional journey."
    : "Parcours recruteur en une seule page : projets, compétences et expériences clés.",
  eyebrow: isEn ? "60-second flow" : "Parcours 60 secondes",
  heroTitle: isEn ? "Launch the recruiter flow" : "Lancez le parcours recruteur",
  heroDesc: isEn
    ? "One page, zero navigation: scroll once to review featured projects, core skills, and professional experience."
    : "Une seule page, zéro navigation : scrollez simplement pour voir les projets phares, les compétences clés et le parcours professionnel.",
};
---

<BaseLayout title={t.title} description={t.description}>
  <div slot="fixed-layer" class="recruiter-scanline" aria-hidden="true"></div>

  <section class="cosmic-container pt-8">
    <p class="rec-eyebrow">{t.eyebrow}</p>
    <h1 class="section-title mt-2">{isEn ? "Launch the" : "Lancez le"} <span class="highlight">{isEn ? "recruiter flow" : "parcours recruteur"}</span></h1>
    <p class="muted mt-4 max-w-3xl text-base md:text-lg">{t.heroDesc}</p>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <a class="rec-pill" href="#projets-phares">{isEn ? "Projects" : "Projets"}</a>
      <a class="rec-pill" href="#competences-cles">{isEn ? "Skills" : "Compétences"}</a>
      <a class="rec-pill" href="#parcours-pro">{isEn ? "Journey" : "Parcours"}</a>
      <a class="rec-pill" href="mailto:alexandrenobletpro@gmail.com">{isEn ? "Contact" : "Contact"}</a>
      <span id="reading-time-badge" class="rec-time-badge" aria-live="polite" aria-atomic="true" aria-label={isEn ? "Reading time" : "Temps de lecture"}>0s</span>
    </div>
  </section>

  <section id="projets-phares" class="cosmic-container mt-14">
    <div class="rec-section-head"><span class="rec-section-num" aria-hidden="true">01</span><div class="rec-section-rule" aria-hidden="true"></div></div>
    <h2 class="rec-section-title mt-3">{isEn ? "Featured projects" : "Projets phares"}</h2>
    <p class="muted mt-2 max-w-2xl text-sm md:text-base">{isEn ? "Concrete outcomes in real-world contexts." : "Réalisations concrètes, contextes réels."}</p>
    <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={{...project, detailPage: project.detailPage ? localizePath(project.detailPage, locale) : undefined}} locale={locale} />)}
    </div>
  </section>

  <section id="competences-cles" class="cosmic-container mt-16">
    <div class="rec-section-head"><span class="rec-section-num" aria-hidden="true">02</span><div class="rec-section-rule" aria-hidden="true"></div></div>
    <h2 class="rec-section-title mt-3">{isEn ? "Core skills" : "Compétences clés"}</h2>
    <p class="muted mt-2 max-w-2xl text-sm md:text-base">{isEn ? "Click a skill to open related proofs." : "Cliquez sur une compétence pour voir les preuves associées."}</p>

    <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {featuredSkills.map((skill) => (
        <button type="button" class="skill-focus-btn w-full text-left" data-skill={skill.name} aria-pressed="false" aria-label={`${isEn ? "Show proofs for" : "Voir les preuves pour"} ${skill.name}`}>
          <SkillOrbit skill={skill} locale={locale} />
        </button>
      ))}
    </div>

    <div id="skill-focus-panel" class="skill-panel" aria-hidden="true" role="region" aria-labelledby="skill-focus-title">
      <div class="skill-panel-inner">
        <div class="skill-panel-top-line" aria-hidden="true"></div>
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="rec-eyebrow">{isEn ? "Skill narrative" : "Narration compétence"}</p>
            <h3 id="skill-focus-title" class="skill-panel-title"></h3>
            <p id="skill-focus-meta" class="skill-panel-meta"></p>
          </div>
          <button id="skill-focus-close" type="button" class="skill-panel-close" aria-label={isEn ? "Close panel" : "Fermer le panneau"}>✕</button>
        </div>
        <div class="skill-panel-rule" aria-hidden="true"></div>
        <div id="skill-focus-content"></div>
      </div>
    </div>
  </section>

  <section id="parcours-pro" class="cosmic-container mt-16">
    <div class="rec-section-head"><span class="rec-section-num" aria-hidden="true">03</span><div class="rec-section-rule" aria-hidden="true"></div></div>
    <h2 class="rec-section-title mt-3">{isEn ? "Professional journey" : "Parcours professionnel"}</h2>
    <p class="muted mt-2 max-w-2xl text-sm md:text-base">{isEn ? "Concrete experience in teams and production contexts." : "Expériences concrètes en entreprise et en équipe."}</p>
    <div class="mt-6 space-y-5">
      {featuredExperience.map((item) => <ExperienceCard item={item} locale={locale} />)}
    </div>
  </section>

  <section class="cosmic-container mt-12 mb-4">
    <Card class="p-6">
      <h2 class="font-display text-3xl text-cosmic-gold">{isEn ? "Go further" : "Aller plus loin"}</h2>
      <p class="muted mt-3 max-w-2xl">{isEn ? "Need a demo, technical details, or a quick exchange?" : "Vous souhaitez une démo, des détails techniques ou un échange rapide ?"}</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a class="rec-pill" href={localizePath('/projects', locale)}>{isEn ? "Explore all projects" : "Explorer tous les projets"}</a>
        <a class="rec-pill" href="mailto:alexandrenobletpro@gmail.com">{isEn ? "Contact me" : "Me contacter"}</a>
      </div>
    </Card>
  </section>
</BaseLayout>

<script define:vars={{ skillNarratives, locale, isEn }} is:inline>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll('#projets-phares a[href^="/projects/"] , #projets-phares a[href^="/en/projects/"]').forEach((link) => {
      const a = link;
      const url = new URL(a.href, window.location.origin);
      url.searchParams.set("from", "recruiter");
      a.href = `${url.pathname}${url.search}`;
      a.addEventListener("click", () => {
        sessionStorage.setItem("project-detail-back-link", `${locale === "en" ? "/en" : ""}/recruiter#projets-phares`);
      });
    });

    const badge = document.getElementById("reading-time-badge");
    if (badge) {
      let elapsed = 0;
      setInterval(() => {
        elapsed += 1;
        badge.textContent = `${elapsed}s`;
      }, 1000);
    }

    const panel = document.getElementById("skill-focus-panel");
    const titleEl = document.getElementById("skill-focus-title");
    const contentEl = document.getElementById("skill-focus-content");
    const closeBtn = document.getElementById("skill-focus-close");
    const skillBtns = document.querySelectorAll(".skill-focus-btn");
    let activeSkill = null;

    const closePanel = () => {
      activeSkill = null;
      panel?.setAttribute("aria-hidden", "true");
      panel?.classList.remove("is-open");
      skillBtns.forEach((b) => {
        b.setAttribute("aria-pressed", "false");
        b.classList.remove("is-active");
      });
    };

    const openPanel = (skillName, triggerBtn) => {
      const data = skillNarratives[skillName];
      if (!panel || !titleEl || !contentEl || !data) return;

      titleEl.textContent = skillName;
      const metaEl = document.getElementById("skill-focus-meta");
      if (metaEl) {
        const y = data.years ?? 0;
        metaEl.textContent = `${data.category} · ${y} ${isEn ? (y > 1 ? "years" : "year") : `an${y > 1 ? "s" : ""}`} · ${data.proficiency}%`;
      }

      const projectsHtml = data.projects.length
        ? data.projects.map((p) => `<a class="proof-chip" href="${p.detailPage ?? '#'}">${p.title}</a>`).join("")
        : `<p class="proof-empty">${isEn ? "No direct project found" : "Aucun projet direct trouvé"}</p>`;

      const expHtml = data.experience.length
        ? data.experience.map((e) => `<div class="proof-exp-card"><span class="proof-exp-role">${e.role}</span><span class="proof-exp-co">${e.company}</span></div>`).join("")
        : `<p class="proof-empty">${isEn ? "No direct experience found" : "Aucune expérience directe trouvée"}</p>`;

      contentEl.innerHTML = `<div class="proof-grid"><div class="proof-col"><p class="proof-col-label">${isEn ? "Projects" : "Projets"}</p><div class="proof-chips-wrap">${projectsHtml}</div></div><div class="proof-col"><p class="proof-col-label">${isEn ? "Experience" : "Expériences"}</p><div class="proof-exps-wrap">${expHtml}</div></div></div>`;

      activeSkill = skillName;
      panel.setAttribute("aria-hidden", "false");
      panel.classList.add("is-open");
      skillBtns.forEach((b) => {
        b.setAttribute("aria-pressed", "false");
        b.classList.remove("is-active");
      });
      triggerBtn.setAttribute("aria-pressed", "true");
      triggerBtn.classList.add("is-active");
    };

    skillBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const name = btn.getAttribute("data-skill") ?? "";
        activeSkill === name ? closePanel() : openPanel(name, btn);
      });
    });

    closeBtn?.addEventListener("click", closePanel);
  });
</script>

<style>
  .recruiter-scanline {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    background-image: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 3px,
      rgba(255, 255, 255, 0.011) 3px,
      rgba(255, 255, 255, 0.011) 4px
    );
  }

  .recruiter-scanline::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 2px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(246, 212, 13, 0.045) 25%,
      rgba(246, 212, 13, 0.07) 50%,
      rgba(246, 212, 13, 0.045) 75%,
      transparent 100%
    );
    animation: scan-sweep 14s linear infinite;
  }

  @keyframes scan-sweep {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(100vh);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .recruiter-scanline::after {
      display: none;
    }

    .recruiter-scanline {
      background-image: none;
    }
  }

  .rec-eyebrow {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--pink, #e3a4d6);
  }

  .rec-section-head {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .rec-section-num {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(246, 212, 13, 0.45);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .rec-section-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      rgba(246, 212, 13, 0.22),
      transparent 70%
    );
  }

  .rec-section-title {
    font-family: var(--font-display, "Cormorant Garamond", serif);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    color: var(--gold, #f6d40d);
  }

  .rec-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 0.75rem;
    border: 1px solid rgba(246, 212, 13, 0.3);
    padding: 0.38rem 1rem;
    font-size: 0.78rem;
    color: rgba(246, 212, 13, 0.88);
    transition:
      background 140ms,
      border-color 140ms;
  }

  .rec-pill:hover {
    background: rgba(246, 212, 13, 0.07);
    border-color: rgba(246, 212, 13, 0.5);
  }

  .rec-time-badge {
    margin-left: auto;
    border-radius: 999px;
    border: 1px solid rgba(246, 212, 13, 0.28);
    padding: 0.28rem 0.9rem;
    font-size: 0.7rem;
    font-variant-numeric: tabular-nums;
    color: rgba(246, 212, 13, 0.8);
    background: rgba(246, 212, 13, 0.04);
    white-space: nowrap;
    transition: color 400ms;
  }

  @media (max-width: 640px) {
    .rec-time-badge {
      margin-left: 0;
      width: 100%;
      text-align: center;
    }
  }

  .skill-focus-btn {
    border-radius: var(--radius-card, 1.6rem);
    cursor: pointer;
  }

  .skill-focus-btn:focus-visible {
    outline: 2px solid rgba(246, 212, 13, 0.55);
    outline-offset: 3px;
  }

  .skill-focus-btn.is-active > :global(.skill-card) {
    border-color: rgba(246, 212, 13, 0.58) !important;
    box-shadow:
      0 0 0 1px rgba(246, 212, 13, 0.18),
      0 0 22px rgba(246, 212, 13, 0.1);
  }

  .skill-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    margin-top: 0;
    transition:
      grid-template-rows 340ms ease,
      opacity 260ms ease,
      margin-top 340ms ease;
  }

  .skill-panel.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    margin-top: 1.75rem;
  }

  .skill-panel-inner {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card, 1.6rem);
    border: 1px solid rgba(246, 212, 13, 0.22);
    background:
      radial-gradient(
        ellipse at 0% 0%,
        rgba(246, 212, 13, 0.06) 0%,
        transparent 55%
      ),
      linear-gradient(
        160deg,
        rgba(38, 43, 64, 0.97) 0%,
        rgba(18, 22, 40, 0.95) 100%
      );
    padding: 1.5rem 1.6rem 1.6rem;
  }

  .skill-panel-top-line {
    position: absolute;
    top: 0;
    left: 2.5rem;
    right: 2.5rem;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(246, 212, 13, 0.55) 30%,
      rgba(246, 212, 13, 0.55) 70%,
      transparent
    );
  }

  .skill-panel-title {
    margin-top: 0.2rem;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    line-height: 1.1;
    color: var(--gold, #f6d40d);
  }

  .skill-panel-meta {
    margin-top: 0.3rem;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: rgba(179, 184, 202, 0.6);
  }

  .skill-panel-rule {
    margin: 1.1rem 0 1.2rem;
    height: 1px;
    background: linear-gradient(
      to right,
      rgba(246, 212, 13, 0.18),
      rgba(246, 212, 13, 0.06) 60%,
      transparent
    );
  }

  .skill-panel-close {
    flex-shrink: 0;
    margin-top: 0.15rem;
    padding: 0.3rem;
    color: rgba(179, 184, 202, 0.45);
    border-radius: 0.4rem;
    border: 1px solid transparent;
    transition:
      color 140ms,
      background 140ms,
      border-color 140ms;
  }

  .skill-panel-close:hover {
    color: var(--gold, #f6d40d);
    background: rgba(246, 212, 13, 0.07);
    border-color: rgba(246, 212, 13, 0.2);
  }

  .skill-panel-close:focus-visible {
    outline: 2px solid rgba(246, 212, 13, 0.55);
  }

  :global(.proof-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
  }

  @media (min-width: 580px) {
    :global(.proof-grid) {
      grid-template-columns: 1fr 1fr;
      gap: 1rem 2.5rem;
    }
  }

  :global(.proof-col-label) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    color: rgba(227, 164, 214, 0.9);
    margin-bottom: 0.75rem;
  }

  :global(.proof-col-label)::before {
    content: "";
    display: inline-block;
    width: 14px;
    height: 1px;
    background: rgba(227, 164, 214, 0.55);
    flex-shrink: 0;
  }

  :global(.proof-chips-wrap) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  :global(.proof-chip) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 0.55rem;
    border: 1px solid rgba(246, 212, 13, 0.3);
    padding: 0.32rem 0.8rem;
    font-size: 0.76rem;
    font-weight: 600;
    color: rgba(246, 212, 13, 0.95);
    background: rgba(246, 212, 13, 0.05);
    transition:
      background 130ms,
      border-color 130ms,
      transform 130ms;
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  :global(.proof-chip)::before {
    content: "↗";
    font-size: 0.6rem;
    opacity: 0.45;
    transition:
      transform 130ms,
      opacity 130ms;
  }

  :global(.proof-chip):hover {
    background: rgba(246, 212, 13, 0.11);
    border-color: rgba(246, 212, 13, 0.58);
    transform: translateY(-1px);
  }

  :global(.proof-chip):hover::before {
    opacity: 1;
    transform: translate(1px, -1px);
  }

  :global(.proof-exps-wrap) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.proof-exp-card) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.55rem 0.85rem;
    border-radius: 0.65rem;
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  :global(.proof-exp-role) {
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(243, 240, 226, 0.92);
    line-height: 1.3;
  }

  :global(.proof-exp-co) {
    font-size: 0.67rem;
    color: rgba(246, 212, 13, 0.58);
    letter-spacing: 0.01em;
  }

  :global(.proof-empty) {
    font-size: 0.73rem;
    font-style: italic;
    color: rgba(179, 184, 202, 0.35);
    padding: 0.15rem 0;
  }
</style>
