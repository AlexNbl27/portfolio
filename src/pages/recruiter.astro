---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/ui/Card.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillOrbit from "../components/SkillOrbit.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import projects from "../data/projects.json";
import skills from "../data/skills.json";
import experiences from "../data/experience.json";

const featuredProjects = projects.filter((p) => p.recruiterFeatured);
const featuredSkills = skills.filter((s) => s.recruiterCore);
const featuredExperience = experiences.filter((e) => e.recruiterVisible);
const skillNarratives = Object.fromEntries(
  featuredSkills.map((skill) => {
    const match = (tech: string) =>
      tech.toLowerCase().includes(skill.name.toLowerCase()) ||
      skill.name.toLowerCase().includes(tech.toLowerCase());

    return [
      skill.name,
      {
        category: skill.category,
        proficiency: skill.proficiency,
        years: skill.yearsOfExperience ?? 0,
        projects: featuredProjects
          .filter((p) => p.technologies.some(match))
          .map((p) => ({ title: p.title, detailPage: p.detailPage })),
        experience: featuredExperience
          .filter((e) => (e.technologies ?? []).some(match))
          .map((e) => ({ role: e.role, company: e.company })),
      },
    ];
  }),
);
---

<BaseLayout
  title="Alexandre Noblet | Parcours recruteur 60 secondes"
  description="Parcours recruteur en une seule page : projets, compétences et expériences clés."
>
  <!-- Scan line in the fixed layer slot so it sits above everything -->
  <div slot="fixed-layer" class="recruiter-scanline" aria-hidden="true"></div>

  <!-- ── Hero ──────────────────────────────────────────────────── -->
  <section class="cosmic-container pt-8">
    <p class="rec-eyebrow">Parcours 60 secondes</p>
    <h1 class="section-title mt-2">
      Lancez le <span class="highlight">parcours recruteur</span>
    </h1>
    <p class="muted mt-4 max-w-3xl text-base md:text-lg">
      Une seule page, zéro navigation : scrollez simplement pour voir les
      projets phares, les compétences clés et le parcours professionnel.
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <a class="rec-pill" href="#projets-phares">Projets</a>
      <a class="rec-pill" href="#competences-cles">Compétences</a>
      <a class="rec-pill" href="#parcours-pro">Parcours</a>
      <a class="rec-pill" href="mailto:alexandrenobletpro@gmail.com">Contact</a>
      <span
        id="reading-time-badge"
        class="rec-time-badge"
        aria-live="polite"
        aria-atomic="true"
        aria-label="Temps de lecture"
      >
        0s
      </span>
    </div>
  </section>

  <!-- ── Section 1 : Projets phares ───────────────────────────── -->
  <section id="projets-phares" class="cosmic-container mt-14">
    <div class="rec-section-head">
      <span class="rec-section-num" aria-hidden="true">01</span>
      <div class="rec-section-rule" aria-hidden="true"></div>
    </div>
    <h2 class="rec-section-title mt-3">Projets phares</h2>
    <p class="muted mt-2 max-w-2xl text-sm md:text-base">
      Réalisations concrètes, contextes réels.
    </p>
    <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <!-- ── Section 2 : Compétences clés ─────────────────────────── -->
  <section id="competences-cles" class="cosmic-container mt-16">
    <div class="rec-section-head">
      <span class="rec-section-num" aria-hidden="true">02</span>
      <div class="rec-section-rule" aria-hidden="true"></div>
    </div>
    <h2 class="rec-section-title mt-3">Compétences clés</h2>
    <p class="muted mt-2 max-w-2xl text-sm md:text-base">
      Cliquez sur une compétence pour voir les preuves associées.
    </p>

    <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        featuredSkills.map((skill) => (
          <button
            type="button"
            class="skill-focus-btn w-full text-left"
            data-skill={skill.name}
            aria-pressed="false"
            aria-label={`Voir les preuves pour ${skill.name}`}
          >
            <SkillOrbit skill={skill} />
          </button>
        ))
      }
    </div>

    <!-- Focus panel — always in DOM, animated with grid-template-rows trick -->
    <div
      id="skill-focus-panel"
      class="skill-panel"
      aria-hidden="true"
      role="region"
      aria-labelledby="skill-focus-title"
    >
      <div class="skill-panel-inner">
        <div class="skill-panel-top-line" aria-hidden="true"></div>
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="rec-eyebrow">Narration compétence</p>
            <h3 id="skill-focus-title" class="skill-panel-title"></h3>
            <p id="skill-focus-meta" class="skill-panel-meta"></p>
          </div>
          <button
            id="skill-focus-close"
            type="button"
            class="skill-panel-close"
            aria-label="Fermer le panneau"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 15 15"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            >
              <line x1="2" y1="2" x2="13" y2="13"></line>
              <line x1="13" y1="2" x2="2" y2="13"></line>
            </svg>
          </button>
        </div>
        <div class="skill-panel-rule" aria-hidden="true"></div>
        <div id="skill-focus-content"></div>
      </div>
    </div>
  </section>

  <!-- ── Section 3 : Parcours professionnel ───────────────────── -->
  <section id="parcours-pro" class="cosmic-container mt-16">
    <div class="rec-section-head">
      <span class="rec-section-num" aria-hidden="true">03</span>
      <div class="rec-section-rule" aria-hidden="true"></div>
    </div>
    <h2 class="rec-section-title mt-3">Parcours professionnel</h2>
    <p class="muted mt-2 max-w-2xl text-sm md:text-base">
      Expériences concrètes en entreprise et en équipe.
    </p>
    <div class="mt-6 space-y-5">
      {featuredExperience.map((item) => <ExperienceCard item={item} />)}
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────── -->
  <section class="cosmic-container mt-12 mb-4">
    <Card class="p-6">
      <h2 class="font-display text-3xl text-cosmic-gold">Aller plus loin</h2>
      <p class="muted mt-3 max-w-2xl">
        Vous souhaitez une démo, des détails techniques ou un échange rapide ?
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a class="rec-pill" href="/projects">Explorer tous les projets</a>
        <a class="rec-pill" href="mailto:alexandrenobletpro@gmail.com"
          >Me contacter</a
        >
      </div>
    </Card>
  </section>
</BaseLayout>

<!-- define:vars + is:inline: passes skillNarratives as a runtime global -->
<script define:vars={{ skillNarratives }} is:inline>
  document.addEventListener("astro:page-load", () => {
    // ── Project links: tag with from=recruiter ──────────────────
    document
      .querySelectorAll('#projets-phares a[href^="/projects/"]')
      .forEach((link) => {
        const a = /** @type {HTMLAnchorElement} */ (link);
        const url = new URL(a.href, window.location.origin);
        url.searchParams.set("from", "recruiter");
        a.href = `${url.pathname}${url.search}`;
        a.addEventListener("click", () => {
          sessionStorage.setItem(
            "project-detail-back-link",
            "/recruiter#projets-phares",
          );
        });
      });

    // ── Time to read badge ──────────────────────────────────────
    const badge = document.getElementById("reading-time-badge");
    if (badge) {
      const STORAGE_KEY = "recruiter-timer-state";
      const EXPIRATION_TIME = 2 * 60 * 60 * 1000;

      let elapsed = 0;
      let started = false;
      try {
        const stored = sessionStorage.getItem(STORAGE_KEY);
        if (stored) {
          const state = JSON.parse(stored);
          if (Date.now() - state.lastUpdated < EXPIRATION_TIME) {
            elapsed = typeof state.elapsed === "number" ? state.elapsed : 0;
          } else {
            sessionStorage.removeItem(STORAGE_KEY);
          }
        }
      } catch (e) {
        // En cas d'erreur de parsing
      }

      if (elapsed > 0) {
        badge.textContent = `${elapsed}s`;
      }

      const tick = () => {
        elapsed += 1;
        badge.textContent = `${elapsed}s`;
        sessionStorage.setItem(
          STORAGE_KEY,
          JSON.stringify({ elapsed, lastUpdated: Date.now() }),
        );
      };

      const startTimer = () => {
        if (started) return;
        started = true;
        badge.textContent = `${elapsed}s`;
        setInterval(tick, 1000);
        window.removeEventListener("scroll", startTimer);
      };

      window.addEventListener("scroll", startTimer, { passive: true });
    }

    // ── Skill focus panel ───────────────────────────────────────
    const panel = document.getElementById("skill-focus-panel");
    const titleEl = document.getElementById("skill-focus-title");
    const contentEl = document.getElementById("skill-focus-content");
    const closeBtn = document.getElementById("skill-focus-close");
    const skillBtns = /** @type {NodeListOf<HTMLButtonElement>} */ (
      document.querySelectorAll(".skill-focus-btn")
    );

    let activeSkill = /** @type {string | null} */ (null);

    const closePanel = () => {
      activeSkill = null;
      panel?.setAttribute("aria-hidden", "true");
      panel?.classList.remove("is-open");
      skillBtns.forEach((b) => {
        b.setAttribute("aria-pressed", "false");
        b.classList.remove("is-active");
      });
    };

    const openPanel = (skillName, triggerBtn) => {
      const data = skillNarratives[skillName];
      if (!panel || !titleEl || !contentEl || !data) return;

      titleEl.textContent = skillName;

      // Meta line: category · X an(s) · proficiency%
      const metaEl = document.getElementById("skill-focus-meta");
      if (metaEl) {
        const y = data.years ?? 0;
        metaEl.textContent = `${data.category}\u2002·\u2002${y}\u00a0an${y > 1 ? "s" : ""}\u2002·\u2002${data.proficiency}\u202f%`;
      }

      const projectsHtml = data.projects.length
        ? data.projects
            .map((p) => {
              const url = p.detailPage
                ? new URL(p.detailPage, window.location.origin)
                : null;
              if (url) url.searchParams.set("from", "recruiter");
              const href = url ? `${url.pathname}${url.search}` : "#";
              return `<a class="proof-chip" href="${href}">${p.title}</a>`;
            })
            .join("")
        : `<p class="proof-empty">Aucun projet direct trouvé</p>`;

      const expHtml = data.experience.length
        ? data.experience
            .map(
              (e) =>
                `<div class="proof-exp-card"><span class="proof-exp-role">${e.role}</span><span class="proof-exp-co">${e.company}</span></div>`,
            )
            .join("")
        : `<p class="proof-empty">Aucune expérience directe trouvée</p>`;

      contentEl.innerHTML = `
        <div class="proof-grid">
          <div class="proof-col">
            <p class="proof-col-label">Projets</p>
            <div class="proof-chips-wrap">${projectsHtml}</div>
          </div>
          <div class="proof-col">
            <p class="proof-col-label">Expériences</p>
            <div class="proof-exps-wrap">${expHtml}</div>
          </div>
        </div>`;

      activeSkill = skillName;
      panel.setAttribute("aria-hidden", "false");
      panel.classList.add("is-open");

      skillBtns.forEach((b) => {
        b.setAttribute("aria-pressed", "false");
        b.classList.remove("is-active");
      });
      triggerBtn.setAttribute("aria-pressed", "true");
      triggerBtn.classList.add("is-active");

      if (window.innerWidth < 768) {
        setTimeout(
          () => panel.scrollIntoView({ behavior: "smooth", block: "nearest" }),
          80,
        );
      }
    };

    skillBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const name = btn.getAttribute("data-skill") ?? "";
        activeSkill === name ? closePanel() : openPanel(name, btn);
      });
    });

    closeBtn?.addEventListener("click", closePanel);

    // ── Setup recruiter source for modal projects ─────────────
    panel?.addEventListener("click", (e) => {
      const target = /** @type {HTMLElement} */ (e.target);
      const isChip =
        target?.classList.contains("proof-chip") ||
        target?.closest(".proof-chip");
      if (isChip) {
        sessionStorage.setItem(
          "project-detail-back-link",
          "/recruiter#competences-cles",
        );
      }
    });
  });
</script>

<style>
  /* ── CRT scan line ──────────────────────────────────────────── */
  .recruiter-scanline {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    /* Very faint repeating horizontal lines */
    background-image: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 3px,
      rgba(255, 255, 255, 0.011) 3px,
      rgba(255, 255, 255, 0.011) 4px
    );
  }

  /* Single slow-moving sweep line */
  .recruiter-scanline::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 2px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(246, 212, 13, 0.045) 25%,
      rgba(246, 212, 13, 0.07) 50%,
      rgba(246, 212, 13, 0.045) 75%,
      transparent 100%
    );
    animation: scan-sweep 14s linear infinite;
  }

  @keyframes scan-sweep {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(100vh);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .recruiter-scanline::after {
      display: none;
    }
    /* Drop scanlines texture too — just disappear cleanly */
    .recruiter-scanline {
      background-image: none;
    }
  }

  /* ── Section headers ────────────────────────────────────────── */
  .rec-eyebrow {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--pink, #e3a4d6);
  }

  .rec-section-head {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .rec-section-num {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(246, 212, 13, 0.45);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .rec-section-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      rgba(246, 212, 13, 0.22),
      transparent 70%
    );
  }

  .rec-section-title {
    font-family: var(--font-display, "Cormorant Garamond", serif);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    color: var(--gold, #f6d40d);
  }

  /* ── Nav pills / time badge ─────────────────────────────────── */
  .rec-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 0.75rem;
    border: 1px solid rgba(246, 212, 13, 0.3);
    padding: 0.38rem 1rem;
    font-size: 0.78rem;
    color: rgba(246, 212, 13, 0.88);
    transition:
      background 140ms,
      border-color 140ms;
  }
  .rec-pill:hover {
    background: rgba(246, 212, 13, 0.07);
    border-color: rgba(246, 212, 13, 0.5);
  }

  .rec-time-badge {
    margin-left: auto;
    border-radius: 999px;
    border: 1px solid rgba(246, 212, 13, 0.28);
    padding: 0.28rem 0.9rem;
    font-size: 0.7rem;
    font-variant-numeric: tabular-nums;
    color: rgba(246, 212, 13, 0.8);
    background: rgba(246, 212, 13, 0.04);
    white-space: nowrap;
    transition: color 400ms;
  }

  @media (max-width: 640px) {
    .rec-time-badge {
      margin-left: 0;
      width: 100%;
      text-align: center;
    }
  }

  /* ── Skill focus button ─────────────────────────────────────── */
  .skill-focus-btn {
    border-radius: var(--radius-card, 1.6rem);
    cursor: pointer;
  }
  .skill-focus-btn:focus-visible {
    outline: 2px solid rgba(246, 212, 13, 0.55);
    outline-offset: 3px;
  }
  /* Highlight active card by targeting the child Card component */
  .skill-focus-btn.is-active > :global(.skill-card) {
    border-color: rgba(246, 212, 13, 0.58) !important;
    box-shadow:
      0 0 0 1px rgba(246, 212, 13, 0.18),
      0 0 22px rgba(246, 212, 13, 0.1);
  }

  /* ── Skill focus panel ──────────────────────────────────────── */
  .skill-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    margin-top: 0;
    transition:
      grid-template-rows 340ms ease,
      opacity 260ms ease,
      margin-top 340ms ease;
  }
  .skill-panel.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    margin-top: 1.75rem;
  }

  .skill-panel-inner {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card, 1.6rem);
    border: 1px solid rgba(246, 212, 13, 0.22);
    background:
      radial-gradient(
        ellipse at 0% 0%,
        rgba(246, 212, 13, 0.06) 0%,
        transparent 55%
      ),
      linear-gradient(
        160deg,
        rgba(38, 43, 64, 0.97) 0%,
        rgba(18, 22, 40, 0.95) 100%
      );
    padding: 1.5rem 1.6rem 1.6rem;
  }

  /* Thin gold accent line at the top of the panel */
  .skill-panel-top-line {
    position: absolute;
    top: 0;
    left: 2.5rem;
    right: 2.5rem;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(246, 212, 13, 0.55) 30%,
      rgba(246, 212, 13, 0.55) 70%,
      transparent
    );
  }

  .skill-panel-title {
    margin-top: 0.2rem;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    line-height: 1.1;
    color: var(--gold, #f6d40d);
  }

  .skill-panel-meta {
    margin-top: 0.3rem;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: rgba(179, 184, 202, 0.6);
  }

  /* Divider between header and content */
  .skill-panel-rule {
    margin: 1.1rem 0 1.2rem;
    height: 1px;
    background: linear-gradient(
      to right,
      rgba(246, 212, 13, 0.18),
      rgba(246, 212, 13, 0.06) 60%,
      transparent
    );
  }

  .skill-panel-close {
    flex-shrink: 0;
    margin-top: 0.15rem;
    padding: 0.3rem;
    color: rgba(179, 184, 202, 0.45);
    border-radius: 0.4rem;
    border: 1px solid transparent;
    transition:
      color 140ms,
      background 140ms,
      border-color 140ms;
  }
  .skill-panel-close:hover {
    color: var(--gold, #f6d40d);
    background: rgba(246, 212, 13, 0.07);
    border-color: rgba(246, 212, 13, 0.2);
  }
  .skill-panel-close:focus-visible {
    outline: 2px solid rgba(246, 212, 13, 0.55);
  }

  /* ── Proof grid — :global() because content is injected via innerHTML ── */
  :global(.proof-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
  }
  @media (min-width: 580px) {
    :global(.proof-grid) {
      grid-template-columns: 1fr 1fr;
      gap: 1rem 2.5rem;
    }
  }

  /* Section label ("Projets" / "Expériences") */
  :global(.proof-col-label) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    color: rgba(227, 164, 214, 0.9);
    margin-bottom: 0.75rem;
  }
  /* Short left-border accent so labels read as section dividers */
  :global(.proof-col-label)::before {
    content: "";
    display: inline-block;
    width: 14px;
    height: 1px;
    background: rgba(227, 164, 214, 0.55);
    flex-shrink: 0;
  }

  /* ── Proof chips (projects) ─────────────────────────────────── */
  :global(.proof-chips-wrap) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  :global(.proof-chip) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 0.55rem;
    border: 1px solid rgba(246, 212, 13, 0.3);
    padding: 0.32rem 0.8rem;
    font-size: 0.76rem;
    font-weight: 600;
    color: rgba(246, 212, 13, 0.95);
    background: rgba(246, 212, 13, 0.05);
    transition:
      background 130ms,
      border-color 130ms,
      transform 130ms;
    text-decoration: none;
    letter-spacing: 0.01em;
  }
  :global(.proof-chip)::before {
    content: "↗";
    font-size: 0.6rem;
    opacity: 0.45;
    transition:
      transform 130ms,
      opacity 130ms;
  }
  :global(.proof-chip):hover {
    background: rgba(246, 212, 13, 0.11);
    border-color: rgba(246, 212, 13, 0.58);
    transform: translateY(-1px);
  }
  :global(.proof-chip):hover::before {
    opacity: 1;
    transform: translate(1px, -1px);
  }

  /* ── Experience cards ────────────────────────────────────────── */
  :global(.proof-exps-wrap) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.proof-exp-card) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.55rem 0.85rem;
    border-radius: 0.65rem;
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  :global(.proof-exp-role) {
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(243, 240, 226, 0.92);
    line-height: 1.3;
  }

  :global(.proof-exp-co) {
    font-size: 0.67rem;
    color: rgba(246, 212, 13, 0.58);
    letter-spacing: 0.01em;
  }

  /* ── Empty states ────────────────────────────────────────────── */
  :global(.proof-empty) {
    font-size: 0.73rem;
    font-style: italic;
    color: rgba(179, 184, 202, 0.35);
    padding: 0.15rem 0;
  }
</style>
