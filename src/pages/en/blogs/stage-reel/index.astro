---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Card from '../../../../components/ui/Card.astro';
---

<BaseLayout title="Stage @ REEL | Blog" description="English overview of the REEL internship section.">
  <section class="cosmic-container page-hero">
    <h1 class="section-title page-hero__title"><span class="highlight">Internship @ REEL</span></h1>
    <p class="muted page-hero__desc mt-4">This section contains internship notes about automation and industrial monitoring.</p>
    <Card class="mt-6 p-5">
      <p class="muted">Detailed posts are currently available in French while translation is in progress.</p>
      <a href="/blogs/stage-reel" class="mt-4 inline-flex focus-ring rounded-xl border border-cosmic-gold/35 px-4 py-2 text-sm text-cosmic-gold hover:bg-cosmic-gold/10 transition">Open French version</a>
    </Card>
  </section>
</BaseLayout>
