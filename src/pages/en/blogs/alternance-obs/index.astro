---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Card from '../../../../components/ui/Card.astro';
---

<BaseLayout title="Apprenticeship @ OBS | Blog" description="English overview of the OBS apprenticeship section.">
  <section class="cosmic-container pt-8">
    <h1 class="section-title"><span class="highlight">Apprenticeship @ OBS</span></h1>
    <p class="muted page-hero__desc mt-4">Apprenticeship notes focused on product delivery, IoT, and Industry 4.0 integration.</p>
    <Card class="mt-6 p-5">
      <p class="muted">Detailed posts are currently available in French while translation is in progress.</p>
      <a href="/blogs/alternance-obs" class="mt-4 inline-flex focus-ring rounded-xl border border-cosmic-gold/35 px-4 py-2 text-sm text-cosmic-gold hover:bg-cosmic-gold/10 transition">Open French version</a>
    </Card>
  </section>
</BaseLayout>
