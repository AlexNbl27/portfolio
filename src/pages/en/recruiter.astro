---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/ui/Card.astro";

const highlights = [
  "Current role: Fullstack developer & IoT integrator at Orange Business Services.",
  "Stack: Astro, TypeScript, Flutter, Python, PostgreSQL, CI/CD.",
  "Focus: product-minded delivery, clear specs, and industrial contexts.",
];
---

<BaseLayout
  title="Alexandre Noblet | Recruiter quick view"
  description="A 60-second recruiter summary: projects, skills, and professional journey."
>
  <section class="cosmic-container pt-8 grid gap-6">
    <Card class="p-6 md:p-8">
      <p class="text-xs uppercase tracking-[0.22em] text-cosmic-pink">Recruiter quick view</p>
      <h1 class="mt-3 font-display text-4xl md:text-5xl text-cosmic-gold">60-second profile</h1>
      <p class="muted mt-4 max-w-3xl">
        A concise overview in English of my profile, strongest projects, technical stack, and delivery mindset.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/en/projects" class="focus-ring rounded-xl border border-cosmic-gold/35 px-4 py-2 text-sm text-cosmic-gold hover:bg-cosmic-gold/10 transition">Top projects</a>
        <a href="/en/skills" class="focus-ring rounded-xl border border-cosmic-gold/35 px-4 py-2 text-sm text-cosmic-gold hover:bg-cosmic-gold/10 transition">Core skills</a>
        <a href="/en/experience" class="focus-ring rounded-xl border border-cosmic-gold/35 px-4 py-2 text-sm text-cosmic-gold hover:bg-cosmic-gold/10 transition">Experience timeline</a>
      </div>
    </Card>

    <Card class="p-6 md:p-8">
      <h2 class="font-display text-3xl text-cosmic-gold">At a glance</h2>
      <ul class="mt-4 space-y-2 muted list-disc pl-5">
        {highlights.map((item) => <li>{item}</li>)}
      </ul>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="mailto:alexandrenobletpro@gmail.com" class="focus-ring rounded-xl border border-cosmic-gold/35 px-4 py-2 text-sm text-cosmic-gold hover:bg-cosmic-gold/10 transition">Contact</a>
      </div>
    </Card>
  </section>
</BaseLayout>
