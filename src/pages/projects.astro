---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectFilter from '../components/ProjectFilter.astro';
import projects from '../data/projects.json';
---

<BaseLayout title="Alexandre Noblet | Projets" description="Découvrez les projets web, mobile, desktop et SaaS d’Alexandre Noblet.">
  <section class="cosmic-container pt-8">
    <h1 class="section-title">Mes <span class="highlight">projets</span></h1>
    <p class="muted mt-4 max-w-3xl text-lg">Une sélection de projets réalisés en formation, en stage ou sur mon temps personnel, avec un intérêt constant pour les produits utiles, concrets et bien pensés.</p>
    <ProjectFilter />
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="project-grid">
      {projects.map((project) => (
        <div
          data-category={project.category}
          data-detail-page={project.detailPage ?? ''}
          class:list={[
            'project-item',
            project.detailPage ? 'project-item--detail cursor-pointer' : 'cursor-default'
          ]}
          tabindex={project.detailPage ? 0 : undefined}
          role={project.detailPage ? 'link' : undefined}
          aria-label={project.detailPage ? `Ouvrir la page de détails du projet ${project.title}` : undefined}
        >
          <ProjectCard project={project} />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  import { navigate } from 'astro:transitions/client';

  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');
      cards.forEach((card) => {
        const visible = category === 'all' || card.getAttribute('data-category') === category;
        const wasHidden = card.classList.contains('hidden');
        card.classList.toggle('hidden', !visible);
        if (visible && wasHidden) {
          const img = card.querySelector('.project-card-img') as HTMLElement | null;
          if (img) {
            img.style.animation = 'none';
            void img.offsetWidth;
            img.style.animation = '';
          }
        }
      });
    });
  });

  cards.forEach((card) => {
    const detailPage = card.getAttribute('data-detail-page');
    if (!detailPage) return;

    card.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      // Allow clicks on external links (demo, github) to work normally
      const link = target?.closest('a');
      if (link && !link.href.includes(detailPage)) return;
      navigate(detailPage);
    });

    card.addEventListener('keydown', (event) => {
      const keyboardEvent = event as KeyboardEvent;
      if (keyboardEvent.key === 'Enter' || keyboardEvent.key === ' ') {
        keyboardEvent.preventDefault();
        navigate(detailPage);
      }
    });
  });
</script>
