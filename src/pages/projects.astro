---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectFilter from '../components/ProjectFilter.astro';
import projects from '../data/projects.json';

const recruiterSpotlight = [
  "Azygo",
  "Kaniot",
  "Moodvie",
];
---

<BaseLayout title="Alexandre Noblet | Projets" description="Découvrez les projets web, mobile, desktop et SaaS d’Alexandre Noblet.">
  <section class="cosmic-container pt-8">
    <h1 class="section-title">Mes <span class="highlight">projets</span></h1>
    <p class="muted mt-4 max-w-3xl text-lg">Une sélection de projets réalisés en formation, en stage ou sur mon temps personnel, avec un intérêt constant pour les produits utiles, concrets et bien pensés.</p>
    <div class="mt-6 rounded-2xl border border-cosmic-gold/20 bg-slate-900/20 p-4 md:p-5">
      <p class="text-xs uppercase tracking-[0.24em] text-cosmic-pink">
        Parcours recruteur
      </p>
      <h2 class="mt-2 font-display text-2xl md:text-3xl text-cosmic-gold">
        60 secondes pour voir l’essentiel
      </h2>
      <p class="muted mt-2 max-w-2xl text-sm md:text-base">
        Activez le mode rapide pour afficher seulement 3 projets clés :
        impact produit, stack technique et exécution.
      </p>
      <div class="mt-4 flex flex-wrap items-center gap-2">
        <button
          id="recruiter-mode-toggle"
          type="button"
          class="focus-ring rounded-xl border border-cosmic-gold/35 px-4 py-2 text-sm text-cosmic-gold transition hover:bg-cosmic-gold/10"
          aria-pressed="false"
        >
          Activer le mode recruteur
        </button>
        <p class="text-xs text-cosmic-gold/70">
          Projets mis en avant : {recruiterSpotlight.join(" • ")}
        </p>
      </div>
    </div>
    <ProjectFilter />
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="project-grid">
      {projects.map((project) => (
        <div
          data-category={project.category}
          data-featured={recruiterSpotlight.includes(project.title) ? 'true' : 'false'}
          data-recruiter-optional={recruiterSpotlight.includes(project.title) ? undefined : 'true'}
          data-recruiter-priority={recruiterSpotlight.includes(project.title) ? 'true' : undefined}
          data-detail-page={project.detailPage ?? ''}
          class:list={[
            'project-item',
            project.detailPage ? 'project-item--detail cursor-pointer' : 'cursor-default'
          ]}
          tabindex={project.detailPage ? 0 : undefined}
          role={project.detailPage ? 'link' : undefined}
          aria-label={project.detailPage ? `Ouvrir la page de détails du projet ${project.title}` : undefined}
        >
          <ProjectCard project={project} />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  import { navigate } from 'astro:transitions/client';

  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-item');
  const recruiterModeToggle = document.getElementById(
    "recruiter-mode-toggle",
  ) as HTMLButtonElement | null;

  let activeCategory = "all";
  let recruiterMode = document.body.getAttribute("data-recruiter-mode") === "on";

  const applyVisibility = () => {
    cards.forEach((card) => {
      const matchesCategory =
        activeCategory === "all" ||
        card.getAttribute("data-category") === activeCategory;
      const isFeatured = card.getAttribute("data-featured") === "true";
      const visible = matchesCategory && (!recruiterMode || isFeatured);

      const wasHidden = card.classList.contains("hidden");
      card.classList.toggle("hidden", !visible);

      if (visible && wasHidden) {
        const img = card.querySelector('.project-card-img') as HTMLElement | null;
        if (img) {
          img.style.animation = 'none';
          void img.offsetWidth;
          img.style.animation = '';
        }
      }
    });
  };

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCategory = btn.getAttribute('data-category') ?? 'all';
      applyVisibility();
    });
  });

  if (recruiterModeToggle) {
    recruiterModeToggle.setAttribute(
      "aria-pressed",
      recruiterMode ? "true" : "false",
    );
    recruiterModeToggle.textContent = recruiterMode
      ? "Désactiver le mode recruteur"
      : "Activer le mode recruteur";
    recruiterModeToggle.classList.toggle("bg-cosmic-gold/10", recruiterMode);

    recruiterModeToggle.addEventListener("click", () => {
      recruiterMode = !recruiterMode;
      document.body.setAttribute("data-recruiter-mode", recruiterMode ? "on" : "off");
      localStorage.setItem(
        "portfolio-recruiter-mode",
        recruiterMode ? "on" : "off",
      );
      recruiterModeToggle.setAttribute(
        "aria-pressed",
        recruiterMode ? "true" : "false",
      );
      recruiterModeToggle.textContent = recruiterMode
        ? "Désactiver le mode recruteur"
        : "Activer le mode recruteur";
      recruiterModeToggle.classList.toggle("bg-cosmic-gold/10", recruiterMode);
      applyVisibility();
    });
  }

  document.addEventListener("portfolio:recruiter-mode", (event) => {
    const customEvent = event as CustomEvent<{ mode: "on" | "off" }>;
    recruiterMode = customEvent.detail?.mode === "on";
    applyVisibility();
    if (!recruiterModeToggle) return;
    recruiterModeToggle.setAttribute(
      "aria-pressed",
      recruiterMode ? "true" : "false",
    );
    recruiterModeToggle.textContent = recruiterMode
      ? "Désactiver le mode recruteur"
      : "Activer le mode recruteur";
    recruiterModeToggle.classList.toggle("bg-cosmic-gold/10", recruiterMode);
  });

  cards.forEach((card) => {
    const detailPage = card.getAttribute('data-detail-page');
    if (!detailPage) return;

    card.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      // Allow clicks on external links (demo, github) to work normally
      const link = target?.closest('a');
      if (link && !link.href.includes(detailPage)) return;
      navigate(detailPage);
    });

    card.addEventListener('keydown', (event) => {
      const keyboardEvent = event as KeyboardEvent;
      if (keyboardEvent.key === 'Enter' || keyboardEvent.key === ' ') {
        keyboardEvent.preventDefault();
        navigate(detailPage);
      }
    });
  });
</script>
