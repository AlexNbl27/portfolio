---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Card from "../components/ui/Card.astro";
import HomePortalTabs from "../components/HomePortalTabs.astro";
import HomeProofStrip from "../components/HomeProofStrip.astro";
import { getLocaleFromPathname, localizePath } from "../i18n/utils";
import { getHomePortalTabs } from "../data/home-portal";

const locale = getLocaleFromPathname(Astro.url.pathname);
const isEn = locale === "en";
const tabs = getHomePortalTabs(locale);
---

<BaseLayout
  title={isEn ? "Alexandre Noblet | Home" : "Alexandre Noblet | Accueil"}
  description={isEn ? "Interactive portal to explore Alexandre Noblet's projects, expertise and services." : "Portail interactif pour explorer les projets, l'expertise et les services d'Alexandre Noblet."}
>
  <Hero locale={locale} />

  <section class="cosmic-container mt-8">
    <Card class="p-5 md:p-6">
      <p class="text-xs uppercase tracking-[0.26em] text-cosmic-pink">{isEn ? "Fast paths" : "Parcours rapides"}</p>
      <h2 class="mt-2 font-display text-3xl md:text-4xl text-cosmic-gold">
        {isEn ? "Choose your route in under a minute." : "Choisissez votre route en moins d'une minute."}
      </h2>
      <p class="muted mt-3 max-w-2xl">
        {isEn ? "Recruiter, client, or curious visitor — each path highlights the most relevant pages." : "Recruteur, client ou visiteur curieux — chaque parcours met en avant les pages les plus pertinentes."}
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a class="focus-ring rounded-xl border border-cosmic-gold/35 px-4 py-2 text-sm text-cosmic-gold hover:bg-cosmic-gold/10 transition" href={localizePath('/recruiter', locale)}>{isEn ? "Recruiter flow" : "Parcours recruteur"}</a>
        <a class="focus-ring rounded-xl border border-white/25 px-4 py-2 text-sm text-white/90 hover:border-cosmic-gold/35 transition" href={localizePath('/services', locale)}>{isEn ? "Services" : "Services"}</a>
        <a class="focus-ring rounded-xl border border-white/25 px-4 py-2 text-sm text-white/90 hover:border-cosmic-gold/35 transition" href={localizePath('/contact', locale)}>{isEn ? "Contact" : "Contact"}</a>
      </div>
    </Card>
  </section>

  <section class="cosmic-container mt-10">
    <h2 class="font-display text-3xl text-cosmic-gold">{isEn ? "Interactive portfolio portal" : "Portail interactif du portfolio"}</h2>
    <p class="muted mt-3 max-w-3xl">{isEn ? "Use this command center to jump directly to what matters." : "Utilisez ce centre de contrôle pour accéder directement à l'essentiel."}</p>
    <div class="mt-5">
      <HomePortalTabs locale={locale} tabs={tabs} />
    </div>
  </section>

  <section class="cosmic-container mt-10 mb-4">
    <HomeProofStrip locale={locale} />
  </section>
</BaseLayout>
