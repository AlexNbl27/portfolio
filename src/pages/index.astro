---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Card from "../components/ui/Card.astro";
import HomePortalTabs from "../components/HomePortalTabs.astro";
import HomeProofStrip from "../components/HomeProofStrip.astro";
import { getLocaleFromPathname, localizePath } from "../i18n/utils";
import { getHomePortalTabs } from "../data/home-portal";

const locale = getLocaleFromPathname(Astro.url.pathname);
const isEn = locale === "en";
const tabs = getHomePortalTabs(locale);
---

<BaseLayout
  title={isEn ? "Alexandre Noblet | Home" : "Alexandre Noblet | Accueil"}
  description={isEn ? "Interactive portal to explore Alexandre Noblet's projects, expertise and services." : "Portail interactif pour explorer les projets, l'expertise et les services d'Alexandre Noblet."}
>
  <Hero locale={locale} />

  <section class="cosmic-container mt-8">
    <div class="recruiter-cta-wrap">
      <Card class="p-4 md:p-6 relative group selection-card">
        <p class="text-xs uppercase tracking-[0.26em] text-cosmic-pink mb-2">{isEn ? "Personalized space" : "Espace personnalisé"}</p>
        <h2 class="fluid-display-xl text-cosmic-gold">
          {isEn ? "Choose your pathway." : "Choisissez votre parcours."}
        </h2>
        <p class="muted mt-3 max-w-2xl text-base">
          {isEn 
            ? "Identify yourself to access the most relevant constellations of projects and expertise for your specific needs." 
            : "Identifiez-vous pour accéder instantanément aux constellations de projets et expertises pensées pour vos besoins."}
        </p>
        
        <div class="mt-4 flex flex-wrap gap-2.5 md:mt-6 md:gap-4">
          <a class="profile-btn profile-btn--gold" href={localizePath('/recruiter', locale)}>
            <span>{isEn ? "Recruiter" : "Espace recruteur"} 🤝</span>
          </a>
          <a class="profile-btn profile-btn--white" href={localizePath('/services', locale)}>
            <span>{isEn ? "Business space" : "Espace business"} 💼</span>
          </a>
          <a class="profile-btn profile-btn--white" href={localizePath('/blogs', locale)}>
            <span>{isEn ? "School space" : "Espace école"} 🎓</span>
          </a>
          <a class="profile-btn profile-btn--white" href="#stellar-compass">
            <span>{isEn ? "Free exploration" : "Exploration Libre"} 🔭</span>
          </a>
        </div>
      </Card>
    </div>
  </section>

  <section id="stellar-compass" class="cosmic-container mt-10">
    <h2 class="fluid-display-lg text-cosmic-gold">{isEn ? "Stellar Compass" : "Boussole Stellaire"}</h2>
    <p class="muted mt-3 max-w-3xl">{isEn ? "Chart your course through the constellations of my projects and expertise." : "Tracez votre route à travers les constellations de mes projets et compétences."}</p>
    <div class="mt-5">
      <HomePortalTabs locale={locale} tabs={tabs} />
    </div>
  </section>

  <section class="cosmic-container mt-10 mb-4">
    <HomeProofStrip locale={locale} />
  </section>
</BaseLayout>
