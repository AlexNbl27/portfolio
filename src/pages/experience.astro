---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import ExperienceFilter from '../components/ExperienceFilter.astro';
import experiences from '../data/experience.json';
---

<BaseLayout title="Alexandre Noblet | Parcours" description="Parcours académique et professionnel d’Alexandre Noblet.">
  <section class="cosmic-container pt-8">
    <h1 class="section-title">Mon <span class="highlight">parcours</span></h1>
    <p class="muted mt-4 max-w-3xl">De la formation GEII à l’informatique, puis à l’IoT en entreprise : un parcours construit entre technique, terrain et développement produit.</p>
  </section>
  <ExperienceFilter />
  <ExperienceTimeline experiences={experiences} />
</BaseLayout>

<script>
  const filters = document.querySelectorAll('.exp-filter');
  const items = document.querySelectorAll('.experience-item');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      filters.forEach((f) => f.classList.remove('border-cosmic-gold/60', 'text-cosmic-gold'));
      btn.classList.add('border-cosmic-gold/60', 'text-cosmic-gold');

      items.forEach((item) => {
        const type = item.getAttribute('data-type') || 'pro';
        const visible = filter === 'all' || type === filter;
        item.classList.toggle('hidden', !visible);
      });
    });
  });
</script>
