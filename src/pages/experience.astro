---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExperienceTimeline from "../components/ExperienceTimeline.astro";
import ExperienceFilter from "../components/ExperienceFilter.astro";
import ScrollPortrait from "../components/ScrollPortrait.astro";
import ScrollAge from "../components/ScrollAge.astro";
import { getLocaleFromPathname } from "../i18n/utils";
import { getExperiences } from "../i18n/data/experiences";
import { useTranslations } from "../i18n/useTranslations";

const locale = getLocaleFromPathname(Astro.url.pathname);
const t = useTranslations(locale);
const experiences = getExperiences(locale);

const portraitImages = [
  "/images/portrait/2026.jpg",
  "/images/portrait/2024.jpg",
  "/images/portrait/2023.jpg",
  "/images/portrait/2021.jpg",
];
---

<BaseLayout
  title={locale === "en"
    ? "Alexandre Noblet | Journey"
    : "Alexandre Noblet | Parcours"}
  description={locale === "en"
    ? "Academic and professional journey of Alexandre Noblet."
    : "Parcours académique et professionnel d’Alexandre Noblet."}
>
  <div slot="fixed-layer" class="hidden lg:block">
    <ScrollPortrait images={portraitImages} />
    <ScrollAge />
  </div>

  <section class="cosmic-container pt-8 lg:pr-[16rem] xl:pr-[18rem]">
    <div class="timeline-content">
      <h1 class="section-title">
        <span class="highlight">{t("experience").title}</span>
      </h1>
      <p class="muted mt-4 max-w-3xl">
        {t("experience").subtitle}
      </p>

      <ExperienceFilter locale={locale} />
      <ExperienceTimeline experiences={experiences} locale={locale} />
    </div>
  </section>

  <div
    id="no-results-exp"
    class="cosmic-container hidden mt-2 py-16 text-center rounded-[3rem] border border-cosmic-gold/10 bg-slate-900/10"
  >
    <p class="text-cosmic-gold/60 text-xl italic font-display">
      {t("experience").noResultsTitle}
    </p>
    <p class="muted text-sm mt-3">
      {t("experience").noResultsDescription}
    </p>
  </div>
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const filters = document.querySelectorAll(".exp-filter");
    const items = document.querySelectorAll(".experience-item");
    const searchInput = document.getElementById(
      "badge-search-input",
    ) as HTMLInputElement;

    let activeFilter = "all";
    let searchQuery = "";
    let isRecruiterMode =
      document.body.getAttribute("data-recruiter-mode") === "on";

    const normalize = (str: string) =>
      str
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .trim();

    const matchesQuery = (target: string, query: string) => {
      const t = normalize(target);
      const q = normalize(query);
      if (t.includes(q)) return true;
      if (
        q.length > 3 &&
        t.length >= q.length - 1 &&
        t.length <= q.length + 1
      ) {
        let dist = 0;
        for (let i = 0; i < Math.min(t.length, q.length); i++) {
          if (t[i] !== q[i]) dist++;
        }
        return dist <= 1;
      }
      return false;
    };

    const updateUI = () => {
      let visibleCount = 0;
      items.forEach((item) => {
        const type = item.getAttribute("data-type") || "pro";
        const recruiterVisible =
          item.getAttribute("data-recruiter-visible") === "true";
        const role = item.getAttribute("data-role") || "";
        const company = item.getAttribute("data-company") || "";
        const desc = item.getAttribute("data-description") || "";

        const matchesType = activeFilter === "all" || type === activeFilter;
        const matchesRecruiter = !isRecruiterMode || recruiterVisible;
        const matchesSearch =
          searchQuery === "" ||
          matchesQuery(role, searchQuery) ||
          matchesQuery(company, searchQuery) ||
          matchesQuery(desc, searchQuery);

        const visible = matchesType && matchesSearch && matchesRecruiter;

        (item as HTMLElement).style.display = visible ? "grid" : "none";

        if (visible) {
          (item as HTMLElement).classList.add("animate-in");
          item.classList.remove(
            "experience-item--left",
            "experience-item--right",
            "md:[&>*:first-child]:order-2",
            "is-subsequent",
          );
          if (visibleCount > 0) {
            item.classList.add("is-subsequent");
          }

          if (visibleCount % 2 === 0) {
            item.classList.add("experience-item--left");
          } else {
            item.classList.add(
              "experience-item--right",
              "md:[&>*:first-child]:order-2",
            );
          }
          visibleCount++;
        }
      });

      const noResults = document.getElementById("no-results-exp");
      const timeline = document.querySelector(".experience-timeline-track");

      if (noResults) {
        noResults.classList.toggle("hidden", visibleCount > 0);
      }

      if (timeline) {
        (timeline as HTMLElement).style.opacity = visibleCount > 0 ? "1" : "0";
      }
    };

    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeFilter = btn.getAttribute("data-filter") || "all";
        filters.forEach((f) => f.classList.remove("is-active"));
        btn.classList.add("is-active");
        updateUI();
      });
    });

    if (searchInput) {
      searchInput.addEventListener("input", (e) => {
        searchQuery = (e.target as HTMLInputElement).value;
        updateUI();
      });
    }

    document.addEventListener("portfolio:recruiter-mode", (event) => {
      const customEvent = event as CustomEvent<{ mode: "on" | "off" }>;
      isRecruiterMode = customEvent.detail?.mode === "on";
      updateUI();
    });

    const allBtn = document.querySelector('[data-filter="all"]');
    if (allBtn) allBtn.classList.add("is-active");
    updateUI();
  });
</script>
