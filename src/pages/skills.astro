---
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillOrbit from "../components/SkillOrbit.astro";
import SkillFilter from "../components/SkillFilter.astro";
import VibeSwitch from "../components/ui/VibeSwitch.astro";
import skills from "../data/skills.json";
import { getLocaleFromPathname } from "../i18n/utils";

const categories = [...new Set(skills.map((skill) => skill.category))];
const locale = getLocaleFromPathname(Astro.url.pathname);
const isEn = locale === "en";
---

<BaseLayout
  title={isEn ? "Alexandre Noblet | Skills" : "Alexandre Noblet | Compétences"}
  description={isEn ? "Technical skills in development, data, DevOps, and industrial automation." : "Compétences techniques d’Alexandre Noblet en développement, data, DevOps et automatisme."}
>
  <section class="cosmic-container pt-8 relative">
    <div class="vibe-active-bg rounded-3xl pointer-events-none"></div>
    <h1 class="section-title relative z-10">
      {isEn ? "My" : "Mes"} <span class="highlight">{isEn ? "skills" : "compétences"}</span>
    </h1>

    <div class="my-6">
      <VibeSwitch id="vibe-toggle" locale={locale} />
    </div>

    <p
      id="skills-desc"
      class="muted mt-4 max-w-2xl text-lg transition-all duration-500 min-h-[4rem]"
    >
      {isEn ? "A technical foundation built around web/mobile development, databases, DevOps practices, and industrial automation." : "Un socle technique construit autour du développement web et mobile, des bases de données, des outils DevOps et de l’automatisme industriel."}
    </p>

    <SkillFilter categories={categories} locale={locale} />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3" id="skill-grid">
      {
        skills.map((skill) => (
          <div
            data-category={skill.category}
            data-name={skill.name}
            data-recruiter-core={skill.recruiterCore ? "true" : "false"}
            class:list={[
              "skill-item flex flex-col",
              skill.isVibeOnly
                ? "vibe-only-item hidden order-first"
                : "order-last",
            ]}
          >
            <SkillOrbit skill={skill} locale={locale} />
          </div>
        ))
      }
    </div>

    <div
      id="no-results"
      class="hidden mt-12 py-12 text-center rounded-[2.5rem] border border-cosmic-gold/10 bg-slate-900/20 backdrop-blur-sm"
    >
      <p class="text-cosmic-gold/60 text-lg italic font-display">
        {isEn ? "No skills match your search... 🌌" : "Aucune compétence ne correspond à votre recherche... 🌌"}
      </p>
      <p class="muted text-sm mt-2">
        {isEn ? "Try different keywords or filters." : "Réessayez avec d'autres mots-clés ou filtres."}
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const filterButtons = document.querySelectorAll(".skill-filter");
    const skillItems = document.querySelectorAll(".skill-item");
    const skillGrid = document.getElementById("skill-grid");
    const vibeToggle = document.getElementById(
      "vibe-toggle",
    ) as HTMLInputElement;
    const skillsDesc = document.getElementById("skills-desc");
    const searchInput = document.getElementById(
      "badge-search-input",
    ) as HTMLInputElement;

    let activeCategory = "all";
    let searchQuery = "";
    let isVibeMode = false;
    let isRecruiterMode =
      document.body.getAttribute("data-recruiter-mode") === "on";
    const isEn = document.documentElement.lang === "en";
    const isReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const originalDesc = isEn
      ? "A technical foundation built around web/mobile development, databases, DevOps practices, and industrial automation."
      : "Un socle technique construit autour du développement web et mobile, des bases de données, des outils DevOps et de l’automatisme industriel.";
    const vibeDesc = isEn
      ? "More than a developer: a <span class='text-red-500 font-bold'>Vibe-Coder</span>. Even when I am not an expert, I can vibe with any stack using AI to deliver quickly."
      : "Plus qu'un développeur, un <span class='text-red-500 font-bold'>Vibe-Coder</span>. Même quand je ne suis pas expert, je 'vibe' avec n'importe quelle techno grâce à l'IA pour délivrer sans friction.";

    // Normalization helper
    const normalize = (str: string) =>
      str
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .trim();

    const matchesQuery = (target: string, query: string) => {
      const t = normalize(target);
      const q = normalize(query);
      if (t.includes(q)) return true;
      if (
        q.length > 3 &&
        t.length >= q.length - 1 &&
        t.length <= q.length + 1
      ) {
        let dist = 0;
        for (let i = 0; i < Math.min(t.length, q.length); i++) {
          if (t[i] !== q[i]) dist++;
        }
        return dist <= 1;
      }
      return false;
    };

    // keepGenerating=true: don't strip is-generating (skeleton stays until revealCards clears it)
    const updateUI = (keepGenerating = false) => {
      let visibleCount = 0;

      skillItems.forEach((item) => {
        const itemCategory = item.getAttribute("data-category") || "";
        const itemName = item.getAttribute("data-name") || "";
        const isVibeOnly = item.classList.contains("vibe-only-item");
        const isRecruiterCore =
          item.getAttribute("data-recruiter-core") === "true";

        const matchesCategory =
          activeCategory === "all" || itemCategory === activeCategory;
        const matchesSearch =
          searchQuery === "" ||
          matchesQuery(itemName, searchQuery) ||
          matchesQuery(itemCategory, searchQuery);
        const matchesVibe = !isVibeOnly || isVibeMode;
        const matchesRecruiter = !isRecruiterMode || isRecruiterCore;

        const visible =
          matchesCategory && matchesSearch && matchesVibe && matchesRecruiter;

        if (visible) {
          item.classList.remove("hidden");
          (item as HTMLElement).style.display = "";
          if (!keepGenerating) item.classList.remove("is-generating");
          visibleCount++;
        } else {
          item.classList.add("hidden");
          item.classList.remove("is-generating");
        }
      });

      const noResults = document.getElementById("no-results");
      if (noResults) noResults.classList.toggle("hidden", visibleCount > 0);
    };

    const animateBoost = (active: boolean) => {
      // Scope to #skill-grid to avoid touching cards on other pages (e.g. recruiter)
      const cards = document.querySelectorAll("#skill-grid .skill-card");

      cards.forEach((card) => {
        const cardEl = card as HTMLElement;
        const textEl = card.querySelector(".proficiency-text");
        const progressEl = card.querySelector(".skill-progress") as HTMLElement;

        const original = parseInt(
          cardEl.getAttribute("data-proficiency") || "0",
        );
        const boosted = parseInt(cardEl.getAttribute("data-boosted") || "0");
        const target = active ? boosted : original;
        const start = active ? original : boosted;

        // Visual class toggle
        cardEl.classList.toggle("vibe-boost", active);

        // Counter animation
        let current = start;
        const duration = 1000;
        const startTime = performance.now();

        const step = (now: number) => {
          const progress = Math.min(1, (now - startTime) / duration);
          const value = Math.floor(start + (target - start) * progress);
          if (textEl) textEl.textContent = value.toString();
          if (progressEl) progressEl.style.width = `${value}%`;

          if (progress < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      });
    };

    // Vibe Toggle Listener
    let activeTypeInterval: any = null;
    let revelationTimeouts: number[] = [];

    if (vibeToggle) {
      vibeToggle.addEventListener("change", (e) => {
        isVibeMode = (e.target as HTMLInputElement).checked;
        document.body.classList.toggle("vibe-mode-on", isVibeMode);

        // Nettoyage des timers précédents si l'utilisateur change d'avis rapidement
        if (activeTypeInterval) clearInterval(activeTypeInterval);
        revelationTimeouts.forEach((t) => clearTimeout(t));
        revelationTimeouts = [];

        // Mark all visible items as generating — skeleton stays until revealCards
        skillItems.forEach((item) => item.classList.add("is-generating"));
        updateUI(true); // true = don't strip is-generating yet

        if (skillsDesc) {
          skillsDesc.style.opacity = "0";

          revelationTimeouts.push(
            window.setTimeout(() => {
              if (isVibeMode) {
                // Mode Vibe : Animation mot par mot
                if (isReducedMotion) {
                  skillsDesc.innerHTML = vibeDesc;
                  skillsDesc.style.opacity = "1";
                  revealCards();
                  return;
                }

                skillsDesc.innerHTML = `
                <div class="flex flex-col gap-2">
                  <div class="flex items-center gap-4">
                    <span class="text-red-500 animate-pulse font-mono tracking-widest text-xs opacity-90">⚡ SÉQUENCE VIBE-CODER — PROJET HAIL MARY</span>
                    <span class="text-white/40 font-mono text-[10px] animate-bounce delay-700">Amaze! Amaze! Amaze!</span>
                  </div>
                  <div id="vibe-typewriter" class="text-lg leading-relaxed text-red-50/90"></div>
                </div>`;
                skillsDesc.style.opacity = "1";

                const container = document.getElementById("vibe-typewriter");
                if (container) {
                  const words = vibeDesc.split(/\s+(?![^<]*>)/g);
                  let wordIdx = 0;

                  activeTypeInterval = setInterval(() => {
                    if (wordIdx < words.length) {
                      container.innerHTML +=
                        (wordIdx === 0 ? "" : " ") + words[wordIdx];
                      wordIdx++;
                    } else {
                      clearInterval(activeTypeInterval);
                      activeTypeInterval = null;
                      revealCards();
                    }
                  }, 100);
                }
              } else {
                // Mode Normal : Révélation immédiate
                skillsDesc.innerHTML = originalDesc;
                skillsDesc.style.opacity = "1";
                revealCards();
              }
            }, 300),
          );
        }

        function revealCards() {
          const visibleItems = Array.from(skillItems)
            .filter((item) => !item.classList.contains("hidden"))
            .sort((a, b) => {
              const aTop = a.classList.contains("order-first") ? 0 : 1;
              const bTop = b.classList.contains("order-first") ? 0 : 1;
              return aTop - bTop;
            });

          let maxDelay = 0;
          const stagger = isReducedMotion ? 0 : isVibeMode ? 80 : 30;

          visibleItems.forEach((item, index) => {
            const delay = index * stagger;
            revelationTimeouts.push(
              window.setTimeout(() => {
                item.classList.remove("is-generating");
              }, delay),
            );
            maxDelay = Math.max(maxDelay, delay);
          });

          revelationTimeouts.push(
            window.setTimeout(() => {
              animateBoost(isVibeMode);
            }, maxDelay + 100),
          );
        }
      });
    }

    // Filter Listeners
    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCategory = button.getAttribute("data-category") || "all";
        filterButtons.forEach((btn) =>
          btn.classList.remove("border-cosmic-gold/60", "text-cosmic-gold"),
        );
        button.classList.add("border-cosmic-gold/60", "text-cosmic-gold");
        updateUI();
      });
    });

    if (searchInput) {
      searchInput.addEventListener("input", (e) => {
        searchQuery = (e.target as HTMLInputElement).value;
        updateUI();
      });
    }

    document.addEventListener(
      "portfolio:recruiter-mode",
      (event) => {
        const customEvent = event as CustomEvent<{ mode: "on" | "off" }>;
        isRecruiterMode = customEvent.detail?.mode === "on";

        if (activeTypeInterval) clearInterval(activeTypeInterval);
        revelationTimeouts.forEach((t) => clearTimeout(t));
        revelationTimeouts = [];
        skillItems.forEach((item) => item.classList.remove("is-generating"));

        updateUI();
        if (isVibeMode) animateBoost(true);
      },
    );

    // Initial state
    const allBtn = document.querySelector('[data-category="all"]');
    if (allBtn)
      allBtn.classList.add("border-cosmic-gold/60", "text-cosmic-gold");
    updateUI();
  });
</script>
